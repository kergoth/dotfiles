#!/bin/sh
# Root-level setup for Ubuntu: create user, install base packages.

set -eu

is_container() {
    [ -f /.dockerenv ] ||
    [ -f /run/.containerenv ] ||
    [ -n "${container:-}" ] ||
    grep -qE 'docker|lxc|containerd' /proc/1/cgroup 2>/dev/null
}

user=$1

if ! getent passwd "$user" >/dev/null 2>&1; then
    echo >&2 "Adding user '$user'"
    useradd -m -s /bin/bash "$user"

    # Install zsh and set as default shell
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install --no-install-recommends -y zsh
    chsh -s /usr/bin/zsh "$user"

    if [ -n "${NO_USER_PASSWORD:-}" ]; then
        : # Explicitly skip password setup.
    elif [ -n "${USER_PASSWORD:-}" ]; then
        echo "$user:$USER_PASSWORD" | chpasswd
    elif [ -t 0 ]; then
        echo >&2 "Input password for $user"
        passwd "$user"
    elif ! is_container; then
        echo >&2 "Error: no password for $user and not in a container."
        echo >&2 "Set USER_PASSWORD, set NO_USER_PASSWORD=1 to skip, or run interactively."
        exit 1
    fi
fi

# Grant sudo access
apt-get update
aDEBIAN_FRONTEND=noninteractive pt-get install --no-install-recommends -y sudo
if is_container; then
    echo "$user ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/"$user"
else
    echo "$user ALL=(ALL:ALL) ALL" > /etc/sudoers.d/"$user"
fi
chmod 0440 /etc/sudoers.d/"$user"

# Install base prerequisites
DEBIAN_FRONTEND=noninteractive apt-get install --no-install-recommends -y \
    bash \
    ca-certificates \
    curl \
    git \
    unzip

rm -rf /var/lib/apt/lists/*
