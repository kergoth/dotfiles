#!/bin/sh

set -eu

pkg() {
    env ASSUME_ALWAYS_YES=YES pkg "$@"
}

user=$1
uid="${2:-}"

if ! pw usershow "$user" >/dev/null 2>&1; then
    pw_args="-n $user -m -s /bin/sh"
    if [ -n "$uid" ]; then
        pw_args="$pw_args -u $uid"
    fi
    # shellcheck disable=SC2086
    pw useradd $pw_args
elif [ -n "$uid" ] && [ "$(id -u "$user")" != "$uid" ]; then
    pw usermod "$user" -u "$uid"
    home=$(pw usershow "$user" | awk -F: '{print $9}')
    group=$(id -gn "$user")
    if [ -n "$home" ] && [ -d "$home" ]; then
        chown -R "$user:$group" "$home"
    fi
fi

pw groupmod wheel -m "$user"

if ! pkg -N; then
    pkg bootstrap
fi
if ! command -v doas >/dev/null 2>&1; then
    pkg install -y doas
fi
if ! [ -e /usr/local/etc/doas.conf ] || ! grep -q "^permit :wheel" /usr/local/etc/doas.conf; then
    echo "permit :wheel" >>/usr/local/etc/doas.conf
fi

if ! command -v bash >/dev/null 2>&1; then
    pkg install -y bash
fi
