#!/bin/sh
# Post-installation setup script for Chimera Linux, prior to setup-system.
# This must be run after a reboot, to allow dinitctl to work properly.

set -eu

is_container() {
    [ -f /.dockerenv ] ||
    [ -f /run/.containerenv ] ||
    [ -n "${container:-}" ] ||
    grep -qE 'docker|lxc|containerd' /proc/1/cgroup 2>/dev/null
}

user=$1
uid="${2:-}"

if ! getent passwd "$user" >/dev/null 2>&1; then
    echo >&2 "Adding user '$user'"
    useradd_args="-m -g users -G wheel,kvm,plugdev"
    if [ -n "$uid" ]; then
        useradd_args="$useradd_args -u $uid"
    fi
    # shellcheck disable=SC2086
    useradd $useradd_args "$user"
    if ! [ -e /usr/bin/zsh ]; then
        apk add --no-interactive zsh
    fi
    chsh -s /usr/bin/zsh "$user"

    if [ -n "${NO_USER_PASSWORD:-}" ]; then
        : # Explicitly skip password setup.
    elif [ -n "${USER_PASSWORD:-}" ]; then
        echo "$user:$USER_PASSWORD" | chpasswd
    elif [ -t 0 ]; then
        echo >&2 "Input password for $user"
        passwd "$user"
    elif ! is_container; then
        echo >&2 "Error: no password for $user and not in a container."
        echo >&2 "Set USER_PASSWORD, set NO_USER_PASSWORD=1 to skip, or run interactively."
        exit 1
    fi
else
    if [ -n "$uid" ] && [ "$(id -u "$user")" != "$uid" ]; then
        usermod -u "$uid" "$user"
        home=$(getent passwd "$user" | cut -d: -f6)
        group=$(id -gn "$user")
        if [ -n "$home" ] && [ -d "$home" ]; then
            chown -R "$user:$group" "$home"
        fi
    fi
    echo >&2 "Adding user '$user' to the wheel group"
    usermod -a -G wheel "$user"
fi

# Configure doas for the wheel group
if is_container; then
    # Replace any password-requiring wheel rule with nopass
    if grep -q "^permit.*:wheel" /etc/doas.conf 2>/dev/null; then
        sed 's/^permit.*:wheel.*/permit nopass :wheel/' /etc/doas.conf >/etc/doas.conf.tmp
        mv /etc/doas.conf.tmp /etc/doas.conf
    else
        echo "permit nopass :wheel" >>/etc/doas.conf
    fi
elif ! [ -e /etc/doas.conf ] || ! grep -q "^permit.*:wheel" /etc/doas.conf; then
    echo "permit :wheel" >>/etc/doas.conf
fi

# Enable the DHCP client service (skip in containers where dinit isn't running)
if command -v dinitctl >/dev/null 2>&1 && dinitctl list >/dev/null 2>&1; then
    if dinitctl list | grep -q dhcpcd && ! dinitctl status dhcpcd | grep -q STARTED; then
        dinitctl enable dhcpcd
    fi
fi

# Install bash for my dotfiles and other scripts
apk add --no-interactive bash

# Install git for my dotfiles
apk add --no-interactive git

# Install unzip for chezmoi 1password-cli usage
apk add --no-interactive unzip

# Install curl for chezmoi installation
apk add --no-interactive curl
