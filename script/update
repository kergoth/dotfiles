#!/usr/bin/env bash

set -euo pipefail

dry_run=0
no_review=0
while [ $# -gt 0 ]; do
    case "$1" in
        -n|--dry-run)
            dry_run=1
            shift
            ;;
        --no-review)
            no_review=1
            shift
            ;;
        -h|--help)
            echo "Usage: script/update [-n|--dry-run] [--no-review]"
            exit 0
            ;;
        *)
            echo >&2 "Usage: script/update [-n|--dry-run] [--no-review]"
            exit 1
            ;;
    esac
done

scriptdir=$(cd "$(dirname "$0")" && pwd -P)
sourcedir=$(dirname "$scriptdir")
PATH="$PATH:$scriptdir:$sourcedir/scripts"

# Detect VCS type
use_jj=0
if [ -d "$sourcedir/.jj" ] && command -v jj >/dev/null 2>&1; then
    use_jj=1
fi

if [ "$dry_run" -eq 1 ]; then
    echo >&2 "Dry run: skipping chezmoi upgrade"
else
    echo >&2 "Updating chezmoi"
    chezmoi upgrade || :
fi

if [ "$dry_run" -eq 1 ]; then
    echo >&2 "Dry run: skipping dotfiles repository sync"
else
    echo >&2 "Updating dotfiles repository"
    if [ "$use_jj" -eq 1 ]; then
        (cd "$sourcedir" && jj git fetch)
        # Don't use chezmoi update (it would try to use git), just apply
        chezmoi apply -R
    else
        # Check if we're on a branch before attempting update
        if (cd "$sourcedir" && git symbolic-ref -q HEAD >/dev/null); then
            chezmoi update -R
        else
            echo >&2 "Warning: Not on a branch, skipping git pull. Fetching only."
            (cd "$sourcedir" && git fetch)
            chezmoi apply -R
        fi
    fi
fi

update_op_cli_versions() {
    if ! command -v python3 >/dev/null 2>&1; then
        echo >&2 "Warning: python3 not available; skipping op CLI version update"
        return 0
    fi

    python3 "$sourcedir/scripts/update-op-cli-versions.py"
}

if [ "$dry_run" -eq 1 ]; then
    echo >&2 "Dry run: skipping op CLI version update"
else
    op_exit=0
    op_changes=$(update_op_cli_versions) || op_exit=$?
    if [ "$op_exit" -ne 0 ]; then
        echo >&2 "Warning: op CLI version update failed (exit $op_exit); skipping"
    elif [ -n "$op_changes" ]; then
        echo >&2 "Updated op CLI versions and checksums"
        {
            echo "Update op CLI versions"
            echo
            echo "$op_changes" | sed 's/^/  /'
        } >"$sourcedir/.git/COMMIT_EDITMSG"
        echo >&2 "Committing op CLI version update"
        if [ "$use_jj" -eq 1 ]; then
            commit_msg=$(cat "$sourcedir/.git/COMMIT_EDITMSG")
            (cd "$sourcedir" && jj commit -m "$commit_msg" \
                home/.chezmoidata/versions.yml)
        else
            (cd "$sourcedir" && git commit -F .git/COMMIT_EDITMSG \
                home/.chezmoidata/versions.yml)
        fi
    fi
fi

if [ -f "$sourcedir/scripts/update-externals-lock.py" ]; then
    echo >&2 "Checking for externals updates"
    if command -v uv >/dev/null 2>&1; then
        # Step 1: Resolve (always, even in dry-run)
        changes_file=$(mktemp)
        cleanup_changes_file() { rm -f "$changes_file"; }
        trap cleanup_changes_file EXIT INT TERM

        resolve_exit=0
        uv run "$sourcedir/scripts/update-externals-lock.py" --dry-run --json > "$changes_file" || resolve_exit=$?

        if [ "$resolve_exit" -eq 2 ]; then
            echo >&2 "No externals updates available"
        elif [ "$resolve_exit" -ne 0 ]; then
            echo >&2 "Warning: externals resolution failed (exit $resolve_exit); skipping"
        else
            # Step 2: Review (unless --no-review)
            if [ "$no_review" -eq 0 ]; then
                uv run python3 -c "
import json, sys
changes = json.load(open(sys.argv[1]))
for c in changes:
    if c.get('review', True):
        print(c['repo'], c['old_sha'], c['new_sha'], c['id'], c.get('ref', 'main'))
" "$changes_file" | while IFS=' ' read -r repo old_sha new_sha name ref; do
                    uv run "$sourcedir/scripts/show-git-changes.py" \
                        "$repo" "$old_sha" "$new_sha" --name "$name" --ref "$ref" || :
                done
            fi

            # Step 3: Decision point
            if [ "$dry_run" -eq 1 ]; then
                echo >&2 "Dry run: externals review complete, not applying"
            else
                apply=1
                if [ "$no_review" -eq 0 ] && [ -t 0 ]; then
                    while true; do
                        printf >&2 "Apply externals updates? [Y/n/d] "
                        read -r answer
                        case "$answer" in
                            ""|[Yy]|[Yy]es) break ;;
                            [Nn]|[Nn]o) apply=0; break ;;
                            [Dd]|[Dd]iff)
                                uv run python3 -c "
import json, sys
changes = json.load(open(sys.argv[1]))
for c in changes:
    if c.get('review', True):
        print(c['repo'], c['old_sha'], c['new_sha'], c['id'], c.get('ref', 'main'))
" "$changes_file" | while IFS=' ' read -r repo old_sha new_sha name ref; do
                                    uv run "$sourcedir/scripts/show-git-changes.py" \
                                        "$repo" "$old_sha" "$new_sha" --name "$name" --ref "$ref" --diff || :
                                done
                                ;;
                            *) echo >&2 "Please answer Y, n, or d" ;;
                        esac
                    done
                fi

                if [ "$apply" -eq 1 ]; then
                    # Step 4: Write lock from pre-resolved data
                    uv run "$sourcedir/scripts/update-externals-lock.py" \
                        --apply-resolved "$changes_file"
                    chezmoi apply -R || :

                    # Step 5: Build commit message and commit
                    {
                        echo "Update pinned externals"
                        echo
                        uv run python3 -c "
import json, sys
changes = json.load(open(sys.argv[1]))
for c in changes:
    old = c['old_sha'][:7]
    new = c['new_sha'][:7]
    ref = c.get('ref', 'main')
    print(f\"  {c['id']}: {old} → {new} ({ref})\")
" "$changes_file"
                    } > "$sourcedir/.git/COMMIT_EDITMSG"
                    echo >&2 "Committing pinned externals update"
                    if [ "$use_jj" -eq 1 ]; then
                        commit_msg=$(cat "$sourcedir/.git/COMMIT_EDITMSG")
                        (cd "$sourcedir" && jj commit -m "$commit_msg" \
                            home/.chezmoidata/externals-lock.yml)
                    else
                        (cd "$sourcedir" && git commit -F .git/COMMIT_EDITMSG \
                            home/.chezmoidata/externals-lock.yml)
                    fi
                else
                    echo >&2 "Skipping externals update"
                    chezmoi apply -R || :
                fi
            fi
        fi
    else
        echo >&2 "Warning: uv not available; skipping externals update"
    fi
fi

if [ "$dry_run" -eq 1 ]; then
    echo >&2 "Dry run: skipping Home Manager switch"
else
    script/home-manager-switch --update-inputs "nixpkgs nixpkgs-unstable" "Update Home Manager packages"
fi
