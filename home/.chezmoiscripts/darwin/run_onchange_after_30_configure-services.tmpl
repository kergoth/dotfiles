{{- if and .user_setup (not .ephemeral) .has_init -}}
#!/usr/bin/env bash
# Configure managed user launchd agents
#
# Onchange triggers: Re-run if managed launchd agent files change
{{- range $plist := (glob (joinPath .chezmoi.sourceDir "Library/LaunchAgents/com.kergoth*.plist*") | sortAlpha) }}
# {{ base $plist }}: {{ include $plist | sha256sum }}
{{- end }}
# session-env binary: {{ if stat (joinPath .chezmoi.destDir ".local/share/session-env/bin/session-env") }}present{{ else }}missing{{ end }}

set -euo pipefail

LAUNCH_AGENTS_DIR="{{ .chezmoi.destDir }}/Library/LaunchAgents"

# Ensure LaunchAgents directory exists
mkdir -p "$LAUNCH_AGENTS_DIR"

# Install or refresh a launchd agent if it exists.
install_agent() {
    local plist_name="$1"
    local service_name="${plist_name%.plist}"
    local plist_path="${LAUNCH_AGENTS_DIR}/${plist_name}"

    if [ ! -f "$plist_path" ]; then
        return 0
    fi

    echo "Installing ${service_name} launchd agent..." >&2

    # Unload if already loaded
    launchctl unload "$plist_path" 2>/dev/null || true

    # Load the agent
    if launchctl load "$plist_path"; then
        echo "✓ ${service_name} agent installed successfully" >&2
    else
        echo "Warning: Failed to load ${service_name} agent" >&2
    fi
}

shopt -s nullglob

for plist_path in "$LAUNCH_AGENTS_DIR"/com.kergoth.*.plist; do
    install_agent "${plist_path##*/}"
done

{{- end -}}
