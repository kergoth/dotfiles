{{- if and .work .secrets (not .ephemeral) -}}
{{-   $toml := joinPath .chezmoi.sourceDir ".chezmoitemplates/external/agent-content-work.toml.age" | include | decrypt | fromToml -}}
#!/usr/bin/env bash
# Work agent content repos — re-run when skills or agents change:
{{- range $path, $_ := $toml }}
# {{ joinPath $.chezmoi.destDir $path "skills/*" | glob | sortAlpha | join "\n" | sha256sum }}
{{- end }}
# Work agent repos — re-run when agents change:
{{- range $path, $_ := $toml }}
# {{ joinPath $.chezmoi.destDir $path "agents/*" | glob | sortAlpha | join "\n" | sha256sum }}
{{- end }}

set -euo pipefail

SKILLS_DIR="$HOME/.agents/skills"
AGENTS_DIR="$HOME/.agents/agents"

REPOS=(
{{- range $path, $_ := $toml }}
    "$HOME/{{ $path }}"
{{- end }}
)

# Create/update symlinks for each skill found in work repos
for repo in "${REPOS[@]}"; do
    skills_src="$repo/skills"
    [ -d "$skills_src" ] || continue

    for skill_dir in "$skills_src"/*/; do
        [ -d "$skill_dir" ] || continue
        skill_name="$(basename "$skill_dir")"
        link="$SKILLS_DIR/$skill_name"

        if [ -L "$link" ]; then
            current="$(readlink "$link")"
            if [ "$current" = "$skill_dir" ] || [ "$current" = "${skill_dir%/}" ]; then
                continue
            fi
            # Stale symlink pointing elsewhere — replace
            rm "$link"
        elif [ -e "$link" ]; then
            echo >&2 "Warning: $link exists and is not a symlink, skipping"
            continue
        fi

        ln -s "${skill_dir%/}" "$link"
        echo "Linked skill: $skill_name -> ${skill_dir%/}"
    done
done

# Create/update symlinks for each agent found in work repos
for repo in "${REPOS[@]}"; do
    agents_src="$repo/agents"
    [ -d "$agents_src" ] || continue

    repo_name="$(basename "$repo")"
    agent_dest="$AGENTS_DIR/$repo_name"
    mkdir -p "$agent_dest"

    for agent_file in "$agents_src"/*.md; do
        [ -f "$agent_file" ] || continue
        agent_name="$(basename "$agent_file")"
        link="$agent_dest/$agent_name"

        if [ -L "$link" ]; then
            current="$(readlink "$link")"
            if [ "$current" = "$agent_file" ]; then
                continue
            fi
            # Stale symlink pointing elsewhere — replace
            rm "$link"
        elif [ -e "$link" ]; then
            echo >&2 "Warning: $link exists and is not a symlink, skipping"
            continue
        fi

        ln -s "$agent_file" "$link"
        echo "Linked agent: $repo_name/$agent_name -> $agent_file"
    done
done

# Clean dead symlinks whose targets pointed into work repos
for link in "$SKILLS_DIR"/*/; do
    [ -L "${link%/}" ] || continue
    link="${link%/}"
    target="$(readlink "$link")"

    # Only clean symlinks pointing into our work repos
    is_work_link=false
    for repo in "${REPOS[@]}"; do
        case "$target" in
            "$repo"*) is_work_link=true; break ;;
        esac
    done

    if $is_work_link && [ ! -e "$link" ]; then
        echo "Removing dead work skill symlink: $(basename "$link")"
        rm "$link"
    fi
done

# Clean dead agent symlinks whose targets pointed into work repos
for repo_dir in "$AGENTS_DIR"/*/; do
    [ -d "$repo_dir" ] || continue

    for link in "$repo_dir"/*.md; do
        [ -L "$link" ] || continue
        target="$(readlink "$link")"

        # Only clean symlinks pointing into our work repos
        is_work_link=false
        for repo in "${REPOS[@]}"; do
            case "$target" in
                "$repo"*) is_work_link=true; break ;;
            esac
        done

        if $is_work_link && [ ! -e "$link" ]; then
            echo "Removing dead work agent symlink: $(basename "$link")"
            rm "$link"
        fi
    done

    # Remove empty repo subdirectory
    rmdir "$repo_dir" 2>/dev/null || true
done
{{ end -}}
