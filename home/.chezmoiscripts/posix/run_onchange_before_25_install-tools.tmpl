{{- if .user_setup -}}
{{-     $chezmoiGithubTokenPath := "" -}}
{{-     if .secrets -}}
{{-       $chezmoiGithubTokenPath = joinPath (printf "%s" .chezmoi.destDir) ".config" "chezmoi_github_token" -}}
{{-     end -}}
{{-     $rusage := includeTemplate "find-tool" (dict "root" . "tool" "rusage") -}}
{{-     $install_rusage := not $rusage -}}
{{-     $install_distrobox := false -}}
{{-     if eq .chezmoi.os "linux" -}}
{{-       $distrobox := includeTemplate "find-tool" (dict "root" . "tool" "distrobox") -}}
{{-       if not $distrobox -}}
{{-         $install_distrobox = true -}}
{{-       end -}}
{{-     end -}}
{{-     $eget_tools := dict -}}
{{-     if eq .osid "linux-chimera" -}}
{{-       $_ := set $eget_tools "choose" "theryangeary/choose" -}}
{{-       $_ := set $eget_tools "dua" "Byron/dua-cli" -}}
{{-       $_ := set $eget_tools "ghq" "x-motemen/ghq" -}}
{{-       $_ := set $eget_tools "sd" "chmln/sd" -}}
{{-       $_ := set $eget_tools "shellcheck" "-a xz koalaman/shellcheck" -}}
{{-       $_ := set $eget_tools "duf" "-a tar muesli/duf" -}}
{{-       if eq .chezmoi.arch "amd64" -}}
{{-         $_ := set $eget_tools "fclones" "pkolaczk/fclones" -}}
{{-       end -}}
{{-       if .work -}}
{{-         $_ := set $eget_tools "jira" "ankitpokhrel/jira-cli" -}}
{{-       end -}}
{{-     end -}}
{{-     $eget_to_install := list -}}
{{-     if $eget_tools -}}
{{-       $eget_to_install = includeTemplate "packagesForMissingTools" (dict "root" . "packages" $eget_tools) | fromJson -}}
{{-     end -}}

{{-     $cargo_tools := dict -}}
{{-     if and (eq .osid "linux-chimera") (ne .chezmoi.arch "amd64") -}}
{{-       $_ := set $cargo_tools "fclones" "fclones" -}}
{{-     end -}}
{{-     $cargo_to_install := list -}}
{{-     if $cargo_tools -}}
{{-       $cargo_to_install = includeTemplate "packagesForMissingTools" (dict "root" . "packages" $cargo_tools) | fromJson -}}
{{-     end -}}
{{-     $cargo := "" -}}
{{-     if $cargo_to_install -}}
{{-       $cargo = includeTemplate "find-tool" (dict "root" . "tool" "cargo") -}}
{{-     end -}}
{{-     $install_cargo_tools := and $cargo $cargo_to_install -}}

{{-     $uv_tools := dict "git-imerge" "git-imerge" "git-revise" "git-revise" -}}
{{-     $uv_to_install := includeTemplate "packagesForMissingTools" (dict "root" . "packages" $uv_tools) | fromJson -}}
{{-     $unar := includeTemplate "find-tool" (dict "root" . "tool" "unar") -}}
{{-     $dtrx := includeTemplate "find-tool" (dict "root" . "tool" "dtrx") -}}
{{-     if and (not $unar) (not $dtrx) -}}
{{-       $uv_to_install = append $uv_to_install "dtrx" -}}
{{-     end -}}
{{-     $uv := "" -}}
{{-     if $uv_to_install -}}
{{-       $uv = includeTemplate "find-tool" (dict "root" . "tool" "uv") -}}
{{-     end -}}
{{-     $install_uv_tools := and $uv $uv_to_install -}}

{{-     $npm_tools := dict -}}
{{-     if eq .chezmoi.os "linux" -}}
{{-       $_ := set $npm_tools "codex" "@openai/codex" -}}
{{-     end -}}
{{-     $npm_to_install := includeTemplate "packagesForMissingTools" (dict "root" . "packages" $npm_tools) | fromJson -}}
{{-     $npm := includeTemplate "find-tool" (dict "root" . "tool" "npm") -}}
{{-     $install_npm_tools := and $npm $npm_to_install -}}
{{-     $lock := .git_lock -}}
{{-     $claude := includeTemplate "find-tool" (dict "root" . "tool" "claude") -}}
{{-     $claude_tag := index $lock "claude_code" -}}
{{-     $claude_version := trimPrefix "v" $claude_tag -}}
{{-     $gh_cmd := includeTemplate "find-tool" (dict "root" . "tool" "gh") -}}

#!/usr/bin/env bash
set -euo pipefail

scriptsdir="$CHEZMOI_WORKING_TREE/scripts"
PATH="$scriptsdir:$PATH"

{{ if or $install_distrobox $eget_to_install -}}
tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT
{{- end }}

{{       if $install_distrobox -}}
echo >&2 "Installing distrobox"
curl -fL -o "$tmpdir/distrobox.tar.gz" \
    https://github.com/89luca89/distrobox/archive/{{ index .git_lock "distrobox" }}.tar.gz
tar -xzf "$tmpdir/distrobox.tar.gz" -C "$tmpdir"
mkdir -p "$HOME/.local/bin"
mv "$tmpdir"/distrobox* "$HOME/.local/bin/"
{{-       end }}

{{       if $eget_to_install }}
{{         $eget_cmd := includeTemplate "find-tool" (dict "root" . "tool" "eget") -}}
{{         if not $eget_cmd }}
echo >&2 "Installing eget"
mkdir -p "$HOME/.local/bin"
fetch-verified \
    -o "$tmpdir/eget.sh" \
    "https://zyedidia.github.io/eget.sh" \
    "{{ index .fetch_lock "eget_installer" }}"
(
    cd "$tmpdir" || exit 1
    sh eget.sh
    mv eget "$HOME/.local/bin/"
)
{{           $eget_cmd = "$HOME/.local/bin/eget" -}}
{{         end }}
{{         range $eget_to_install }}
echo >&2 "Installing {{ . }}"
"{{ $eget_cmd }}" --to="$HOME/.local/bin" {{ . }}
{{         end }}
{{       end }}

{{       if $install_cargo_tools }}
{{         range $cargo_to_install }}
echo >&2 "Installing {{ . }}"
"{{ $cargo }}" install --locked {{ . }}
{{         end }}
{{       end }}

{{       if $install_uv_tools }}
{{         range $uv_to_install }}
"{{ $uv }}" tool install {{ . }}
{{         end }}
{{       end }}

need_claude_install=0
current_claude_version=""
if command -v claude >/dev/null 2>&1; then
    current_claude_version=$(claude --version 2>/dev/null | sed -E 's/.*([0-9]+\.[0-9]+\.[0-9]+).*/\1/' | head -n1)
fi
if [ "$current_claude_version" != "{{ $claude_version }}" ]; then
    need_claude_install=1
fi

{{       if and (eq .chezmoi.os "darwin") $claude }}
if command -v brew >/dev/null 2>&1 && brew list --cask claude-code >/dev/null 2>&1; then
    echo >&2 "Removing legacy Homebrew Claude Code install"
    brew uninstall --cask claude-code
    need_claude_install=1
    hash -r
fi
{{       end }}

{{       if and (eq .chezmoi.os "linux") $claude }}
if command -v npm >/dev/null 2>&1 && npm list -g @anthropic-ai/claude-code >/dev/null 2>&1; then
    echo >&2 "Removing legacy npm Claude Code install"
    npm uninstall -g @anthropic-ai/claude-code || true
    need_claude_install=1
    hash -r
fi
{{       end }}

{{       if not .steamdeck }}
{{         if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") }}
if [ "$need_claude_install" -eq 1 ]; then
    echo >&2 "Installing Claude Code {{ $claude_version }} via official installer"
    curl -fsSL https://claude.ai/install.sh | bash -s {{ $claude_version }}
fi
{{         end }}
{{       end }}

{{       if eq .chezmoi.os "freebsd" }}
if [ "$need_claude_install" -eq 1 ]; then
    echo >&2 "Installing Claude Code {{ $claude_version }} via pinned npm package"
    if ! command -v npm >/dev/null 2>&1; then
        echo >&2 "npm is required to install Claude Code on FreeBSD"
        exit 1
    fi
    export NPM_CONFIG_PREFIX="$HOME/.local"
    export NPM_CONFIG_CACHE="$HOME/.cache/npm"
    export NPM_CONFIG_FUND=false
    export NPM_CONFIG_AUDIT=false
    "{{ $npm }}" install -g @anthropic-ai/claude-code@{{ $claude_version }}
fi
{{       end }}

{{       if $install_npm_tools }}
# TODO: this duplicates what's already in npmrc, either move this to after_,
# or force early application like we do with the home-manager files.
export NPM_CONFIG_PREFIX="$HOME/.local"
export NPM_CONFIG_CACHE="$HOME/.cache/npm"
export NPM_CONFIG_FUND=false
export NPM_CONFIG_AUDIT=false
{{         range $npm_to_install }}
"{{ $npm }}" install -g {{ . }}
{{         end }}
{{       end }}

{{       if $install_rusage }}
echo >&2 "Installing rusage"
mkdir -p "$HOME/.local/bin"
fetch-verified \
    -o "$HOME/.local/bin/rusage" \
    "https://cosmo.zip/pub/cosmos/bin/rusage" \
    "{{ index .fetch_lock "rusage" }}"
chmod +x "$HOME/.local/bin/rusage"
{{       end }}

{{   if $gh_cmd -}}
{{     if and $chezmoiGithubTokenPath (stat $chezmoiGithubTokenPath) -}}
export GH_TOKEN="$(cat {{ $chezmoiGithubTokenPath }})"
{{     end -}}
echo >&2 "Installing gh extensions"
{{ $gh_cmd }} extension install --pin {{ index $lock "gh_pr_review" }} agynio/gh-pr-review
{{   end }}
{{ end -}}
