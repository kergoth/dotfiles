{{- $nix := includeTemplate "find-tool" (dict "root" . "tool" "nix") -}}
{{- if and .user_setup .use_nix $nix -}}
#!/usr/bin/env bash
# Apply home manager configuration
#
# Re-run when home-manager configuration changes:
#   home.nix hash: {{ includeTemplate "dot_config/home-manager/home.nix.tmpl" . | sha256sum }}
#   flake.nix hash: {{ includeTemplate "dot_config/home-manager/flake.nix.tmpl" . | sha256sum }}
#   flake.lock hash: {{ include "dot_config/home-manager/private_flake.lock" | sha256sum }}
# Re-run after installing nix:
#   nix binary path: {{ $nix }}

set -euo pipefail

find "$CHEZMOI_SOURCE_DIR/dot_config/home-manager" -name \*.nix -o -name \*.nix.tmpl -o -name \*.pem -o -name \*.pem.tmpl -o -name \*.lock |
    while read -r src; do
        file="${src#"$CHEZMOI_SOURCE_DIR/dot_config/"}"
        dest="$CHEZMOI_HOME_DIR/.config/${file%.tmpl}"
        case "$file" in
            */private_*)
                private=1
                base=$(basename "$dest")
                dest="$(dirname "$dest")/${base#private_}"
                ;;
            *)
                private=0
                ;;
        esac

        if ! [ -e "$dest" ] || [ "$src" -nt "$dest" ]; then
            mkdir -p "$(dirname "$dest")"
            case "$file" in
            *.tmpl)
                chezmoi execute-template <"$src" >"$dest" || {
                    rm -f "$dest"
                    echo >&2 "Error processing chezmoi template $src"
                    exit 1
                }
                if ! [ -s "$dest" ]; then
                    # Without empty_, chezmoi doesn't apply empty files
                    rm -f "$dest"
                fi
                ;;
            *)
                cp -af "$src" "$dest"
                ;;
            esac
            if [ "$private" -eq 1 ]; then
                chmod go-rwx "$dest"
            fi
        fi
    done

echo >&2 "Applying home manager configuration"
export USER="${USER:-${LOGNAME:-$(whoami)}}"
{{- if .work }}
# Bitdefender SSL inspection requires a combined CA bundle for Nix curl.
# home.sessionVariables sets this for future shells, but the activation
# script running right now needs it too. Skip if already configured.
if [ -n "${SSL_CERT_FILE:-}" ] && grep -q "Bitdefender" "$SSL_CERT_FILE" 2>/dev/null; then
    : # SSL_CERT_FILE already includes Bitdefender CA
else
    hm_certs="$CHEZMOI_HOME_DIR/.config/home-manager/certs"
    if [ -f "$hm_certs/bitdefender-ca-ssl.pem" ]; then
        combined=$(mktemp)
        cat "$CHEZMOI_HOME_DIR/.nix-profile/etc/ssl/certs/ca-bundle.crt" \
            "$hm_certs/bitdefender-ca-ssl.pem" > "$combined"
        export SSL_CERT_FILE="$combined"
        export NIX_SSL_CERT_FILE="$combined"
        trap 'rm -f "$combined"' EXIT
    fi
fi
{{- end }}
HOME="$CHEZMOI_HOME_DIR" "{{ $nix }}" run 'home-manager/master' -- switch
{{- end -}}
