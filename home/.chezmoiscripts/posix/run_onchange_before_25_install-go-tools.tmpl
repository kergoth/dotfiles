{{- if and .user_setup (not .use_nix) (eq .osid "linux-chimera") -}}
{{-   $go_tools := dict "duf" "github.com/muesli/duf/...@latest" -}}
{{-   if .work -}}
{{-     $_ := set $go_tools "jira" "github.com/ankitpokhrel/jira-cli/...@latest" -}}
{{-   end -}}
{{-   $to_install := includeTemplate "packagesForMissingTools" (dict "root" . "packages" $go_tools) | fromJson -}}
{{-   if $to_install -}}
{{-     $go := includeTemplate "find-tool" (dict "root" . "tool" "go") -}}
{{-     if $go -}}
#!/bin/sh
set -eu

{{-       range $to_install }}
echo >&2 "Installing go tool: {{ . }}"
"{{ $go }}" install {{ . }}
{{-       end }}
{{-     end }}
{{-   end }}
{{- end }}
