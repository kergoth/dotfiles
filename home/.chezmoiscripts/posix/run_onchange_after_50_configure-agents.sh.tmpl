{{- $codex := includeTemplate "find-tool" (dict "root" . "tool" "codex") -}}
{{- $claude := includeTemplate "find-tool" (dict "root" . "tool" "claude") -}}
{{- if or $claude $codex -}}
#!/usr/bin/env bash

claude_has_mcp_server() {
    # claude mcp list works but runs a health check adding latency;
    # checking the config file directly with jq is faster
    jq -e --arg name "$1" '.mcpServers[$name] // empty' ~/.claude.json >/dev/null 2>&1
}

claude_add_mcp_server() {
    local name="$1"; shift
{{- if stat (joinPath (printf "%s" .chezmoi.destDir) ".claude.json") }}
    if claude_has_mcp_server "$name"; then
        return 0
    fi
{{- end }}
    claude mcp add "$name" "$@" || { echo "Failed to add MCP server: $name" >&2; return 1; }
}

codex_has_mcp_server() {
    grep -Fxq "[mcp_servers.$1]" ~/.codex/config.toml 2>/dev/null
}

codex_add_mcp_server() {
    local name="$1"; shift
{{- if stat (joinPath (printf "%s" .chezmoi.destDir) ".codex/config.toml") }}
    if codex_has_mcp_server "$name"; then
        return 0
    fi
{{- end }}
    codex mcp add "$name" "$@" || { echo "Failed to add MCP server: $name" >&2; return 1; }
}

add_mcp_json() {
    local name="$1"
    local json="$2"
    shift 2
{{- if stat (joinPath (printf "%s" .chezmoi.destDir) ".claude.json") }}
    if claude_has_mcp_server "$name"; then
        return 0
    fi
{{- end }}
    claude mcp add-json "$@" "$name" "$json" || { echo "Failed to add MCP server: $name" >&2; return 1; }
}

plugin_enabled() {
    jq -e --arg name "$1" '.enabledPlugins[$name] // empty' ~/.claude/settings.json >/dev/null 2>&1
}

install_plugin() {
    local name="$1"; shift
{{- if stat (joinPath (printf "%s" .chezmoi.destDir) ".claude" "settings.json") }}
    if plugin_enabled "$name"; then
        return 0
    fi
{{- end }}
    claude plugin install "$name" "$@" || { echo "Failed to install plugin: $name" >&2; return 1; }
}

has_marketplace() {
    jq -e --arg repo "$1" 'any(.[]; .source.repo == $repo)' ~/.claude/plugins/known_marketplaces.json >/dev/null 2>&1
}

add_marketplace() {
    local repo="$1"; shift
{{- if stat (joinPath (printf "%s" .chezmoi.destDir) ".claude" "plugins" "known_marketplaces.json") }}
    if has_marketplace "$repo"; then
        return 0
    fi
{{- end }}
    claude plugin marketplace add "$repo" "$@" || { echo "Failed to add marketplace: $repo" >&2; return 1; }
}


{{ if and $codex ( not .work ) -}}
codex_add_mcp_server deepwiki --url https://mcp.deepwiki.com/mcp
codex_add_mcp_server context7 -- npx -y @upstash/context7-mcp

{{   if and .personal ( not .ephemeral ) -}}
codex_add_mcp_server readwise --url https://mcp2.readwise.io/mcp
{{-   end }}
{{- end }}

{{   if $claude -}}
claude_add_mcp_server deepwiki --scope user --transport http https://mcp.deepwiki.com/mcp
add_mcp_json context7 '{"type":"stdio","command":"npx","args":["-y","@upstash/context7-mcp"]}' --scope user

{{   if and .personal ( not .ephemeral ) -}}
claude_add_mcp_server readwise --scope user --transport http https://mcp2.readwise.io/mcp
{{-   end }}

{{   if .work -}}
{{ joinPath .chezmoi.workingTree "settings/agents/work-mcp-claude.sh.age" | include | decrypt }}
{{-   end }}

add_marketplace astral-sh/claude-code-plugins
install_plugin astral@astral-sh --scope user

add_marketplace anthropics/claude-plugins-official
install_plugin superpowers@claude-plugins-official --scope user

{{-   end }}
{{- end }}
