{{- $claude := includeTemplate "find-tool" (dict "root" . "tool" "claude") -}}
{{- if $claude -}}
{{-   $github_token := or (env "GITHUB_PERSONAL_ACCESS_TOKEN") (env "GITHUB_TOKEN") -}}
#requires -Version 7.0

Set-StrictMode -Version Latest
$ErrorActionPreference = 'Stop'

function Get-JsonFile {
    param(
        [Parameter(Mandatory)]
        [string]$Path
    )

    if (-not (Test-Path -LiteralPath $Path -PathType Leaf)) {
        return $null
    }

    try {
        $raw = Get-Content -LiteralPath $Path -Raw -ErrorAction Stop
        if ([string]::IsNullOrWhiteSpace($raw)) {
            return $null
        }
        return $raw | ConvertFrom-Json -ErrorAction Stop
    } catch {
        # Treat unreadable/invalid JSON as "unknown"; caller can decide to proceed.
        return $null
    }
}

function Test-HasMcpServer {
    param(
        [Parameter(Mandatory)]
        [string]$Name
    )

    $cfgPath = Join-Path $HOME ".claude.json"
    $cfg = Get-JsonFile -Path $cfgPath
    if ($null -eq $cfg) {
        return $false
    }

    # Expected schema: { "mcpServers": { "<name>": { ... } } }
    $servers = $cfg.mcpServers
    if ($null -eq $servers) {
        return $false
    }

    $prop = $servers.PSObject.Properties[$Name]
    return ($null -ne $prop) -and ($null -ne $prop.Value)
}

function Add-McpServer {
    param(
        [Parameter(Mandatory)]
        [string]$Name,

        [Parameter(Mandatory)]
        [string]$Url,

        [Parameter()]
        [string]$Transport,

        [Parameter()]
        [string]$Scope
    )

{{- if stat (joinPath (printf "%s" .chezmoi.destDir) ".claude.json") }}
    if (Test-HasMcpServer -Name $Name) {
        return
    }
{{- end }}

    try {
        $args = @()
        if (-not [string]::IsNullOrWhiteSpace($Scope)) {
            $args += @('--scope', $Scope)
        }
        if (-not [string]::IsNullOrWhiteSpace($Transport)) {
            $args += @('--transport', $Transport)
        }
        & claude mcp add @args $Name $Url
        if ($LASTEXITCODE -ne 0) {
            throw "claude mcp add failed with exit code $LASTEXITCODE"
        }
    } catch {
        Write-Error "Failed to add MCP server: $Name. $($_.Exception.Message)"
        exit 1
    }
}

function Add-McpJson {
    param(
        [Parameter(Mandatory)]
        [string]$Name,

        [Parameter(Mandatory)]
        [string]$Json,

        [Parameter()]
        [string]$Scope
    )

{{- if stat (joinPath (printf "%s" .chezmoi.destDir) ".claude.json") }}
    if (Test-HasMcpServer -Name $Name) {
        return
    }
{{- end }}

    try {
        if ([string]::IsNullOrWhiteSpace($Scope)) {
            & claude mcp add-json $Name $Json
        } else {
            & claude mcp add-json --scope $Scope $Name $Json
        }
        if ($LASTEXITCODE -ne 0) {
            throw "claude mcp add-json failed with exit code $LASTEXITCODE"
        }
    } catch {
        Write-Error "Failed to add MCP server: $Name. $($_.Exception.Message)"
        exit 1
    }
}

function Test-PluginEnabled {
    param(
        [Parameter(Mandatory)]
        [string]$Name
    )

    $settingsPath = Join-Path (Join-Path $HOME ".claude") "settings.json"
    $settings = Get-JsonFile -Path $settingsPath
    if ($null -eq $settings) {
        return $false
    }

    # Expected schema: { "enabledPlugins": { "<name>": ... } }
    $enabled = $settings.enabledPlugins
    if ($null -eq $enabled) {
        return $false
    }

    $prop = $enabled.PSObject.Properties[$Name]
    return ($null -ne $prop) -and ($null -ne $prop.Value)
}

function Install-Plugin {
    param(
        [Parameter(Mandatory)]
        [string]$Name,

        [Parameter()]
        [string]$Scope
    )

{{- if stat (joinPath (printf "%s" .chezmoi.destDir) ".claude" "settings.json") }}
    if (Test-PluginEnabled -Name $Name) {
        return
    }
{{- end }}

    try {
        if ([string]::IsNullOrWhiteSpace($Scope)) {
            & claude plugin install $Name
        } else {
            & claude plugin install $Name --scope $Scope
        }
        if ($LASTEXITCODE -ne 0) {
            throw "claude plugin install failed with exit code $LASTEXITCODE"
        }
    } catch {
        Write-Error "Failed to install plugin: $Name. $($_.Exception.Message)"
        exit 1
    }
}

function Test-HasMarketplace {
    param(
        [Parameter(Mandatory)]
        [string]$Repo
    )

    $mpPath = Join-Path (Join-Path $HOME ".claude") (Join-Path "plugins" "known_marketplaces.json")
    $mp = Get-JsonFile -Path $mpPath
    if ($null -eq $mp) {
        return $false
    }

    foreach ($prop in $mp.PSObject.Properties) {
        if ($prop.Value.source.repo -eq $Repo) {
            return $true
        }
    }
    return $false
}

function Add-Marketplace {
    param(
        [Parameter(Mandatory)]
        [string]$Repo
    )

{{- if stat (joinPath (printf "%s" .chezmoi.destDir) ".claude" "plugins" "known_marketplaces.json") }}
    if (Test-HasMarketplace -Repo $Repo) {
        return
    }
{{- end }}

    try {
        & claude plugin marketplace add $Repo
        if ($LASTEXITCODE -ne 0) {
            throw "claude plugin marketplace add failed with exit code $LASTEXITCODE"
        }
    } catch {
        Write-Error "Failed to add marketplace: $Repo. $($_.Exception.Message)"
        exit 1
    }
}

Add-McpServer -Name deepwiki -Url https://mcp.deepwiki.com/mcp -Transport http -Scope user

Add-Marketplace astral-sh/claude-code-plugins
Install-Plugin -Name astral@astral-sh -Scope user

Add-Marketplace anthropics/claude-plugins-official
Install-Plugin -Name superpowers@claude-plugins-official -Scope user

{{   if $github_token -}}
$githubMcpJson = '{"type":"http","url":"https://api.githubcopilot.com/mcp","headers":{"Authorization":"Bearer {{ $github_token }}"}}'
Add-McpJson -Name github -Json $githubMcpJson -Scope user
{{-   end }}
{{- end }}
