{{- $calibre := "" -}}
{{- if and .user_setup (not .headless) .ebook_library (not .work) -}}
{{-   $calibre = includeTemplate "find-tool" (dict "root" . "tool" "calibre") -}}
{{- end -}}
{{- $picard := "" -}}
{{- if and .user_setup (not .headless) .music_library -}}
{{-   $picard = includeTemplate "find-tool" (dict "root" . "tool" "picard") -}}
{{- end -}}
{{- $scummvm := "" -}}
{{- if and .user_setup (not .headless) .gaming_device_library -}}
{{-   $scummvm = includeTemplate "find-tool" (dict "root" . "tool" "scummvm") -}}
{{- end -}}
{{- $rpi_imager := "" -}}
{{- if and .user_setup (not .headless) .work -}}
{{-   $rpi_imager = includeTemplate "find-tool" (dict "root" . "tool" "rpi-imager") -}}
{{- end -}}
{{- if and .user_setup (not .headless) -}}
# GUI Applications
. $env:CHEZMOI_COMMAND_DIR\scripts\common.ps1

if (Install-Scoop-IfNotPresent 7zip 7zip.7zip) {
    reg import "$env:SCOOP\apps\7zip\current\install-context.reg" | Out-Null
}
Install-Scoop-IfNotPresent autohotkey AutoHotkey.AutoHotkey | Out-Null
Install-Scoop-IfNotPresent discord Discord.Discord | Out-Null
Install-Scoop-IfNotPresent ditto Ditto.Ditto | Out-Null
Install-Scoop-IfNotPresent devdocs egoist.devdocs-desktop | Out-Null
Install-Scoop-IfNotPresent gsudo gerardog.gsudo | Out-Null
Install-Scoop-IfNotPresent gpg4win GnuPG.Gpg4win | Out-Null
Install-Scoop-IfNotPresent bulk-crap-uninstaller Klocman.BulkCrapUninstaller | Out-Null
Install-Scoop-IfNotPresent pwsh Microsoft.PowerShell | Out-Null
Install-Scoop-IfNotPresent nodejs-lts OpenJS.NodeJS.LTS | Out-Null
if (Install-Scoop-IfNotPresent powertoys Microsoft.PowerToys) {
    Invoke-Expression -Command "C:\Users\WDAGUtilityAccount\scoop\apps\powertoys\current\install-context.ps1"
}
if (Install-Scoop-IfNotPresent windows-terminal Microsoft.WindowsTerminal) {
    reg import "$env:SCOOP\apps\windows-terminal\current\install-context.reg" | Out-Null
}
if (Install-Scoop-IfNotPresent notepadplusplus Notepad++.Notepad++) {
    reg import "$env:SCOOP\apps\notepadplusplus\current\install-context.reg" | Out-Null
}
Install-Scoop-IfNotPresent obsidian Obsidian.Obsidian | Out-Null
Install-Scoop-IfNotPresent squirreldisk squirreldisk.SquirrelDisk | Out-Null
Install-Scoop-IfNotPresent synctrayzor SyncTrayzor.SyncTrayzor | Out-Null
Install-Scoop-IfNotPresent vivaldi Vivaldi.Vivaldi | Out-Null
scoop install zed

{{    if and .gaming_device_library (not $scummvm) -}}
if (-not (scoop bucket list | Select-String -Pattern '^games\\s' -Quiet)) {
    scoop bucket add games
}
scoop install games/scummvm
{{-   end }}

{{    if and .music_library (not $picard) -}}
scoop install picard
{{-   end }}

{{    if .work -}}
{{      if not $rpi_imager -}}
scoop install raspberry-pi-imager
{{-     end }}
{{    else }}
{{/* not .work */}}
Install-Scoop-IfNotPresent sumatrapdf SumatraPDF.SumatraPDF | Out-Null

{{      if not .ephemeral }}
if (-not (Test-Path "$env:LOCALAPPDATA\Programs\Reader\readwise-reader.exe")) {
    Write-Host "Installing Readwise Reader"
    $readerRelease = Invoke-RestMethod "https://api.github.com/repos/readwiseio/reader-desktop-releases/releases/latest"
    $readerExeUrl = ($readerRelease.assets | Where-Object { $_.name -match "x64-setup\.exe$" } | Select-Object -First 1).browser_download_url
    $readerSetupPath = Join-Path $env:TEMP "reader-setup.exe"
    Invoke-WebRequest -Uri $readerExeUrl -OutFile $readerSetupPath
    & $readerSetupPath /S "/D=$env:LOCALAPPDATA\Programs\Reader"
    Remove-Item $readerSetupPath -ErrorAction SilentlyContinue
}
{{-     end }}
{{      if .gaming -}}
Install-Scoop-IfNotPresent steam Valve.Steam | Out-Null

$steamLinkExe = Join-Path $env:LOCALAPPDATA "Programs\\Steam Link\\SteamLink.exe"
if (-not (Test-Path $steamLinkExe)) {
    Write-Host "Installing Steam Link"
    $steamLinkZipUrl = "https://media.steampowered.com/steamlink/windows/latest/SteamLink.zip"
    $steamLinkZipPath = Join-Path $env:TEMP "steamlink.zip"
    $steamLinkExtractPath = Join-Path $env:TEMP "steamlink"
    $steamLinkMsiPath = Join-Path $steamLinkExtractPath "SteamLink.msi"
    Invoke-WebRequest -Uri $steamLinkZipUrl -OutFile $steamLinkZipPath
    if (Test-Path $steamLinkExtractPath) {
        Remove-Item $steamLinkExtractPath -Recurse -Force
    }
    Expand-Archive -Path $steamLinkZipPath -DestinationPath $steamLinkExtractPath -Force
    if (Test-Path $steamLinkMsiPath) {
        Start-Process msiexec.exe -ArgumentList @(
            "/i", $steamLinkMsiPath,
            "/qn",
            "/norestart",
            "MSIINSTALLPERUSER=1",
            "ALLUSERS=2",
            "/l*v", (Join-Path $env:TEMP "steamlink-msi.log")
        ) -NoNewWindow -Wait
    } else {
        Write-Host "Steam Link MSI not found after extracting zip"
    }
    Remove-Item $steamLinkZipPath -ErrorAction SilentlyContinue
    Remove-Item $steamLinkExtractPath -Recurse -Force -ErrorAction SilentlyContinue
}
{{-     end }}
{{      if .retro_computing -}}
scoop install 86box 86box-roms
{{-     end }}
{{      if .video -}}
Install-Scoop-IfNotPresent vlc VideoLAN.VLC | Out-Null
{{-     end }}
{{      if and .ebook_library (not $calibre) -}}
scoop install calibre
{{-     end }}
{{-   end }}
{{    if and .coding .containers (not .ephemeral) -}}
Install-Scoop-IfNotPresent devpod LoftLabs.DevPod | Out-Null
{{    end -}}

RefreshEnvPath
{{- end }}
