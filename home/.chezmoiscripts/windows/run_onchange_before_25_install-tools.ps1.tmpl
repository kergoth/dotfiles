{{- if .user_setup -}}
{{-     $chezmoiGithubTokenPath := "" -}}
{{-     if .secrets -}}
{{-       $chezmoiGithubTokenPath = joinPath (printf "%s" .chezmoi.destDir) ".config" "chezmoi_github_token" -}}
{{-     end -}}
# Install tools via Scoop (Scoop bootstrapped by before_00).

. $env:CHEZMOI_COMMAND_DIR\scripts\common.ps1

RefreshEnvPath

{{-   $rusage := includeTemplate "find-tool" (dict "root" . "tool" "rusage") -}}
{{-   $lock := .git_lock -}}
{{-   $claude_version := trimPrefix "v" (index $lock "claude_code") -}}
{{-   $codex_tag := index $lock "codex_cli" -}}
{{-   $codex_version := trimPrefix "rust-v" $codex_tag -}}
{{-   $codex_windows_target_map := dict "amd64" "x86_64-pc-windows-msvc" "arm64" "aarch64-pc-windows-msvc" -}}
{{-   $codex_windows_fetch_key_map := dict "amd64" "codex_windows_amd64_release" "arm64" "codex_windows_arm64_release" -}}
{{-   $codex_rust_target := index $codex_windows_target_map .chezmoi.arch -}}
{{-   $codex_sha256 := "" -}}
{{-   $codex_url := "" -}}
{{-   if $codex_rust_target -}}
{{-     $codex_sha256 = index .fetch_lock (index $codex_windows_fetch_key_map .chezmoi.arch) -}}
{{-     $codex_url = printf "https://github.com/openai/codex/releases/download/%s/codex-%s.exe.tar.gz" $codex_tag $codex_rust_target -}}
{{-   end -}}
{{-   $codex_direct_install := eq (len $codex_sha256) 64 -}}
{{-   $gh_cmd := includeTemplate "find-tool" (dict "root" . "tool" "gh") -}}

{{/* Note: tmux and zsh are unavailable on Windows */}}
{{/* Starship is used for the PS prompt. While it isn't Windows specific, I only use it there */}}
{{-   $scoop_tools := dict
        "atuin" "atuin"
        "bat" "bat"
        "batman" "bat-extras"
        "cargo" "rust"
        "curl" "curl"
        "delta" "delta"
        "difft" "difftastic"
        "direnv" "direnv"
        "dua" "dua"
        "duf" "duf"
        "fclones" "fclones"
        "fd" "fd"
        "fzf" "fzf"
        "gh" "gh"
        "ghq" "ghq"
        "git-absorb" "git-absorb"
        "git-lfs" "git-lfs"
        "glow" "glow"
        "jira" "jira-cli"
        "jj" "jj"
        "jq" "jq"
        "less" "less"
        "npiperelay" "npiperelay"
        "nvim" "neovim"
        "python" "python"
        "recycle" "recycle-bin"
        "restic" "restic"
        "rg" "ripgrep"
        "sad" "sad"
        "sd" "sd"
        "shellcheck" "shellcheck"
        "shfmt" "shfmt"
        "starship" "starship"
        "tail" "gow"
        "tldr" "tealdeer"
        "unar" "unar"
        "uv" "uv"
        "wget" "wget"
        "zoxide" "zoxide"
        "zstd" "zstd"
-}}
{{-   $scoop_to_install := includeTemplate "packagesForMissingTools" (dict "root" . "packages" $scoop_tools) | fromJson -}}
{{-   if $scoop_to_install -}}
{{-     range $scoop_to_install -}}
scoop install {{ . }}
{{-       if eq . "python" -}}

{{-       $scoop_python := joinPath (printf "%s" .chezmoi.destDir) "scoop" "apps" "python" "current" -}}
reg import "{{ $scoop_python }}\install-pep-514.reg"
{{-       end -}}
{{-     end -}}
{{-   end -}}

$currentClaudeVersion = ""
if (Get-Command claude -ErrorAction SilentlyContinue) {
    $versionOutput = & claude --version 2>$null
    if ($versionOutput -match '([0-9]+\.[0-9]+\.[0-9]+)') {
        $currentClaudeVersion = $Matches[1]
    }
}
$needClaudeInstall = $currentClaudeVersion -ne "{{ $claude_version }}"

if (Get-Command scoop -ErrorAction SilentlyContinue) {
    $scoopClaude = scoop list claude-code 2>$null
    if ($LASTEXITCODE -eq 0 -and $scoopClaude) {
        Write-Host "Removing legacy Scoop Claude Code install"
        scoop uninstall claude-code
        $needClaudeInstall = $true
    }
}

if ($needClaudeInstall) {
    Write-Host "Installing Claude Code {{ $claude_version }} via official installer"
    & ([scriptblock]::Create((irm https://claude.ai/install.ps1))) {{ $claude_version }}
}

{{-   if $codex_direct_install }}

$currentCodexVersion = ""
if (Get-Command codex -ErrorAction SilentlyContinue) {
    $versionOutput = & codex --version 2>$null
    if ($versionOutput -match '([0-9]+\.[0-9]+\.[0-9]+)') {
        $currentCodexVersion = $Matches[1]
    }
}
if ($currentCodexVersion -ne "{{ $codex_version }}") {
    Write-Host "Installing Codex {{ $codex_version }}"
    $codexTmpDir = Join-Path $env:TEMP "codex-install-$([System.IO.Path]::GetRandomFileName())"
    New-Item -ItemType Directory -Path $codexTmpDir -Force | Out-Null
    try {
        $codexArchive = Join-Path $codexTmpDir "codex.exe.tar.gz"
        & "$env:CHEZMOI_COMMAND_DIR\scripts\fetch-verified.ps1" `
            "{{ $codex_url }}" `
            "{{ $codex_sha256 }}" `
            -OutFile $codexArchive
        tar -xzf $codexArchive -C $codexTmpDir
        $codexExe = Get-ChildItem -Path $codexTmpDir -Filter "codex.exe" -Recurse | Select-Object -First 1
        New-Item -ItemType Directory -Path $env:XDG_BIN_HOME -Force | Out-Null
        Move-Item -Force $codexExe.FullName (Join-Path $env:XDG_BIN_HOME "codex.exe")
    } finally {
        Remove-Item -Recurse -Force $codexTmpDir
    }
}
{{-   end }}

{{-   $cargo_git_tools := dict "choose" "--git https://github.com/theryangeary/choose" -}}
{{-   $cargo_to_install := includeTemplate "packagesForMissingTools" (dict "root" . "packages" $cargo_git_tools) | fromJson -}}
{{-   if $cargo_to_install -}}
{{-     $cargo_path := includeTemplate "find-tool" (dict "root" . "tool" "cargo") -}}
{{-     if $cargo_path }}
{{-       range $cargo_to_install }}
Write-Host "Installing cargo tool: {{ . }}"
& "{{ $cargo_path }}" install {{ . }}
{{-       end }}
{{-     end }}
{{-   end }}

{{-   $uv_tools := dict "git-imerge" "git-imerge" "git-revise" "git-revise" -}}
{{-   $uv_to_install := includeTemplate "packagesForMissingTools" (dict "root" . "packages" $uv_tools) | fromJson -}}
{{-   $unar := includeTemplate "find-tool" (dict "root" . "tool" "unar") -}}
{{-   $dtrx := includeTemplate "find-tool" (dict "root" . "tool" "dtrx") -}}
{{-   if and (not $unar) (not $dtrx) -}}
{{-     $uv_to_install = append $uv_to_install "dtrx" -}}
{{-   end -}}
{{-   if $uv_to_install -}}
{{-     $uv_path := includeTemplate "find-tool" (dict "root" . "tool" "uv") -}}
{{-     if $uv_path }}
{{-       range $uv_to_install }}
& "{{ $uv_path }}" tool install {{ . }}
{{-       end }}
{{-     end }}
{{-   end }}
{{-   if not $rusage -}}

Write-Host "Installing rusage"
New-Item -ItemType Directory -Path $env:XDG_BIN_HOME -Force | Out-Null
& "$env:CHEZMOI_COMMAND_DIR\scripts\fetch-verified.ps1" `
    "https://cosmo.zip/pub/cosmos/bin/rusage" `
    "{{ index .fetch_lock "rusage" }}" `
    -OutFile (Join-Path $env:XDG_BIN_HOME "rusage")
{{-   end }}

{{   if $gh_cmd -}}
{{     if and $chezmoiGithubTokenPath (stat $chezmoiGithubTokenPath) -}}
$env:GH_TOKEN = Get-Content -Raw -Path "{{ $chezmoiGithubTokenPath }}"
{{     end -}}
Write-Host "Installing gh extensions"
{{ $gh_cmd }} extension install --pin {{ index $lock "gh_dash" }} dlvhdr/gh-dash
{{ $gh_cmd }} extension install --pin {{ index $lock "gh_pr_review" }} agynio/gh-pr-review
{{-   end }}
{{- end }}
