{{- if .secrets -}}
{{-   $ageKeyPath := .chezmoi.config.age.identity -}}
{{-   $st := stat $ageKeyPath -}}
{{-   if or (not $st) (eq $st.size 0) (env "OP_BOOTSTRAP_FORCE") -}}
{{-     $op := includeTemplate "find-tool" (dict "root" . "tool" "op") -}}
{{-     if or (not $op) (env "OP_BOOTSTRAP_FORCE") -}}
{{-       $op_cli := .versions.op_cli.linux -}}
{{-       $op_cli_version := $op_cli.version -}}
{{-       $op_cli_checksums := $op_cli.sha256 -}}
#!/bin/sh
# Age key: {{ $st }}

set -eu

tmpdir=$(mktemp -d -t install-package-manager.XXXXXX)
if [ -z "${OP_BOOTSTRAP_KEEP_TMP:-}" ]; then
    trap 'rm -rf "$tmpdir"' EXIT INT TERM
else
    echo >&2 "OP_BOOTSTRAP_KEEP_TMP set; leaving temp dir at $tmpdir"
fi

case "$(uname -m)" in
x86_64)
    ARCH=amd64
    CHECKSUM="{{ index $op_cli_checksums "amd64" }}"
    ;;
arm64|aarch64)
    ARCH=arm64
    CHECKSUM="{{ index $op_cli_checksums "arm64" }}"
    ;;
*)
    echo >&2 "Error: unsupported arch from uname -m: $(uname -m)"
    exit 1
    ;;
esac
if [ -z "${CHECKSUM:-}" ]; then
    echo >&2 "Error: no checksum available for arch $ARCH"
    exit 1
fi

op_url="https://cache.agilebits.com/dist/1P/op2/pkg/v{{ $op_cli_version }}/op_linux_${ARCH}_v{{ $op_cli_version }}.zip"
op_zip="$tmpdir/op.zip"

if command -v curl >/dev/null 2>&1; then
    curl -fsSLo "$op_zip" "$op_url"
elif command -v wget >/dev/null 2>&1; then
    wget -qO "$op_zip" "$op_url"
else
    echo >&2 "Error: curl or wget required to download 1Password CLI"
    exit 1
fi

if command -v sha256sum >/dev/null 2>&1; then
    echo "$CHECKSUM  $op_zip" | sha256sum -c -
elif command -v shasum >/dev/null 2>&1; then
    echo "$CHECKSUM  $op_zip" | shasum -a 256 -c -
elif command -v sha256 >/dev/null 2>&1; then
    actual=$(sha256 -q "$op_zip")
    [ "$actual" = "$CHECKSUM" ]
else
    echo >&2 "Error: no sha256 tool available; cannot verify checksum"
    exit 1
fi

unzip -o -d ~/.local/bin "$op_zip" op
chmod +x ~/.local/bin/op
{{-     end -}}
{{-   end -}}
{{- end -}}
