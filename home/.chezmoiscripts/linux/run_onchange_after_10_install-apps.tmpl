{{- $zed := "" -}}
{{- $vivaldi := "" -}}
{{- $kitty := "" -}}
{{- $devpod := "" -}}
{{- $86box := "" -}}
{{- $scummvm := "" -}}
{{- $picard := "" -}}
{{- $calibre := "" -}}
{{- $vlc := "" -}}
{{- $obsidian := "" -}}
{{- $discord := "" -}}
{{- $trguing := "" -}}
{{- $flatpak := "" -}}
{{- $need_install := false -}}
{{- if not .headless -}}
{{-   $flatpak = includeTemplate "find-tool" (dict "root" . "tool" "flatpak") -}}
{{- end -}}
{{- if and .user_setup (not .headless) (not .steamdeck) (not (env "CONTAINER_ID")) -}}
{{-   if not (eq .osid "linux-chimera") -}}
{{-     $zed = includeTemplate "find-tool" (dict "root" . "tool" "zed") -}}
{{-     $vivaldi = includeTemplate "find-tool" (dict "root" . "tool" "vivaldi") -}}
{{-   end -}}
{{-   $obsidian = includeTemplate "find-tool" (dict "root" . "tool" "obsidian") -}}
{{-   $discord = includeTemplate "find-tool" (dict "root" . "tool" "discord") -}}
{{-   if not .work -}}
{{-     $trguing = includeTemplate "find-tool" (dict "root" . "tool" "trguing") -}}
{{-   end -}}
{{-   if or (eq .osid "linux-debian") (eq .osid "linux-ubuntu") -}}
{{-     $kitty = includeTemplate "find-tool" (dict "root" . "tool" "kitty") -}}
{{-   end -}}
{{-   if .retro_computing -}}
{{-     $86box = includeTemplate "find-tool" (dict "root" . "tool" "86box") -}}
{{-   end -}}
{{-   if .gaming_device_library -}}
{{-     $scummvm = includeTemplate "find-tool" (dict "root" . "tool" "scummvm") -}}
{{-   end -}}
{{-   if .music_library -}}
{{-     $picard = includeTemplate "find-tool" (dict "root" . "tool" "picard") -}}
{{-   end -}}
{{-   if .ebook_library -}}
{{-     $calibre = includeTemplate "find-tool" (dict "root" . "tool" "calibre") -}}
{{-   end -}}
{{-   if .video -}}
{{-     $vlc = includeTemplate "find-tool" (dict "root" . "tool" "vlc") -}}
{{-   end -}}
{{-   if and (not $zed) (not (eq .osid "linux-chimera")) -}}{{- $need_install = true -}}{{- end -}}
{{-   if and (not $vivaldi) $flatpak (not (eq .osid "linux-chimera")) -}}{{- $need_install = true -}}{{- end -}}
{{-   if and (not $obsidian) $flatpak -}}{{- $need_install = true -}}{{- end -}}
{{-   if and (not $discord) $flatpak -}}{{- $need_install = true -}}{{- end -}}
{{-   if and (not .work) (not $trguing) $flatpak -}}{{- $need_install = true -}}{{- end -}}
{{-   if and (or (eq .osid "linux-debian") (eq .osid "linux-ubuntu")) (not $kitty) -}}{{- $need_install = true -}}{{- end -}}
{{-   if and .retro_computing (not $86box) $flatpak -}}{{- $need_install = true -}}{{- end -}}
{{-   if and .gaming_device_library (not $scummvm) $flatpak -}}{{- $need_install = true -}}{{- end -}}
{{-   if and .music_library (not $picard) $flatpak -}}{{- $need_install = true -}}{{- end -}}
{{-   if and .ebook_library (not $calibre) $flatpak -}}{{- $need_install = true -}}{{- end -}}
{{-   if and .video (not $vlc) $flatpak -}}{{- $need_install = true -}}{{- end -}}
{{-   if and .gaming $flatpak (eq .chezmoi.arch "amd64") -}}{{- $need_install = true -}}{{- end -}}
{{- end -}}
{{- if and .coding .containers -}}
{{-   $devpod = includeTemplate "find-tool" (dict "root" . "tool" "devpod") -}}
{{-   if not $devpod -}}{{- $need_install = true -}}{{- end -}}
{{- end -}}
{{- if $need_install -}}
#!/usr/bin/env bash

set -euo pipefail

scriptsdir="$CHEZMOI_WORKING_TREE/scripts"
PATH="$scriptsdir:$PATH"

# shellcheck source=./common.sh
. "$scriptsdir/common.sh" || exit 1

{{-   if $flatpak }}
flatpak remote-add --if-not-exists --user flathub https://flathub.org/repo/flathub.flatpakrepo || true
{{-   end }}

{{-   if and (not $zed) (not (eq .osid "linux-chimera")) }}
msg "Installing Zed"
curl -f https://zed.dev/install.sh | sh
{{-   end }}

{{-   if and (not $vivaldi) $flatpak }}
msg "Installing Vivaldi from Flathub"
flatpak install -y --user flathub com.vivaldi.Vivaldi || true
{{-   end }}

{{-   if and (not $obsidian) $flatpak }}
msg "Installing Obsidian from Flathub"
flatpak install -y --user flathub md.obsidian.Obsidian || true
{{-   end }}

{{-   if and (not $discord) $flatpak }}
msg "Installing Discord from Flathub"
flatpak install -y --user flathub com.discordapp.Discord || true
{{-   end }}

{{-   if and (not .work) (not $trguing) $flatpak }}
msg "Installing TrguiNG from Flathub"
flatpak install -y --user flathub org.openscopeproject.TrguiNG || true
{{-   end }}

{{-   if and .retro_computing (not $86box) $flatpak }}
msg "Installing 86Box from Flathub"
flatpak install -y --user flathub net._86box._86Box || true
{{-   end }}

{{-   if and .gaming_device_library (not $scummvm) $flatpak }}
msg "Installing ScummVM from Flathub"
flatpak install -y --user flathub org.scummvm.ScummVM || true
{{-   end }}

{{-   if and .music_library (not $picard) $flatpak }}
msg "Installing MusicBrainz Picard from Flathub"
flatpak install -y --user flathub org.musicbrainz.Picard || true
{{-   end }}

{{-   if and .ebook_library (not $calibre) $flatpak }}
msg "Installing Calibre from Flathub"
flatpak install -y --user flathub com.calibre_ebook.calibre || true
{{-   end }}

{{-   if and .video (not $vlc) $flatpak }}
msg "Installing VLC from Flathub"
flatpak install -y --user flathub org.videolan.VLC || true
{{-   end }}

{{-   if and .gaming $flatpak (eq .chezmoi.arch "amd64") }}
if ! flatpak info --user com.valvesoftware.SteamLink >/dev/null 2>&1 && ! flatpak info com.valvesoftware.SteamLink >/dev/null 2>&1; then
    msg "Installing Steam Link from Flathub"
    flatpak install -y --user flathub com.valvesoftware.SteamLink || true
fi
{{-   end }}

{{-   if and (or (eq .osid "linux-debian") (eq .osid "linux-ubuntu")) (not $kitty) }}
msg "Installing kitty"
curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin launch=n
mkdir -p ~/.local/bin ~/.local/share/applications
cp ~/.local/kitty.app/share/applications/kitty.desktop ~/.local/share/applications/ 2>/dev/null || true
cp ~/.local/kitty.app/share/applications/kitty-open.desktop ~/.local/share/applications/ 2>/dev/null || true
sed -i "s|Icon=kitty|Icon=$HOME/.local/kitty.app/share/icons/hicolor/256x256/apps/kitty.png|g" ~/.local/share/applications/kitty*.desktop 2>/dev/null || true
sed -i "s|Exec=kitty|Exec=$HOME/.local/kitty.app/bin/kitty|g" ~/.local/share/applications/kitty*.desktop 2>/dev/null || true
ln -sf ~/.local/kitty.app/bin/kitty ~/.local/kitty.app/bin/kitten ~/.local/bin/
{{-   end }}

{{-   if and .coding .containers (not $devpod) }}
msg "Installing DevPod CLI"
devpod_arch="amd64"
case "$(uname -m)" in
    aarch64|arm64) devpod_arch="arm64" ;;
esac
curl -L -o /tmp/devpod "https://github.com/loft-sh/devpod/releases/latest/download/devpod-linux-$devpod_arch"
install -c -m 0755 /tmp/devpod "$HOME/.local/bin/devpod"
rm -f /tmp/devpod
{{-   end }}
{{- end }}
