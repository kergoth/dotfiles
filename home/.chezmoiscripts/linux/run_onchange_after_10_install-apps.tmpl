{{- $zed := "" -}}
{{- $kitty := "" -}}
{{- $devpod := "" -}}
{{- $flatpak := "" -}}
{{- $flatpak_apps := dict -}}
{{- $flatpak_to_install := list -}}
{{- $need_install := false -}}
{{- $kitty_version := "" -}}
{{- $linux_amd64 := eq .chezmoi.arch "amd64" -}}
{{- $linux_arm64 := or (eq .chezmoi.arch "arm64") (eq .chezmoi.arch "aarch64") -}}
{{- if not .headless -}}
{{-   $flatpak = includeTemplate "find-tool" (dict "root" . "tool" "flatpak") -}}
{{- end -}}
{{- if and .user_setup (not .headless) (not .steamdeck) (not (env "CONTAINER_ID")) -}}
{{-   if not (eq .osid "linux-chimera") -}}
{{-     $zed = includeTemplate "find-tool" (dict "root" . "tool" "zed") -}}
{{-   end -}}
{{-   if or (eq .osid "linux-debian") (eq .osid "linux-ubuntu") -}}
{{-     $kitty = includeTemplate "find-tool" (dict "root" . "tool" "kitty") -}}
{{-     $kitty_version = index .git_lock "kitty" | trimPrefix "v" -}}
{{-   end -}}
{{-   if $flatpak -}}
{{-     $_ := set $flatpak_apps "md.obsidian.Obsidian" "md.obsidian.Obsidian" -}}
{{-     if $linux_amd64 -}}
{{-       $_ := set $flatpak_apps "com.discordapp.Discord" "com.discordapp.Discord" -}}
{{-     end -}}
{{-     if $linux_arm64 -}}
{{-       $_ := set $flatpak_apps "dev.vencord.Vesktop" "dev.vencord.Vesktop" -}}
{{-     end -}}
{{-     if not .ephemeral -}}
{{-       $_ := set $flatpak_apps "io.github.martchus.syncthingtray" "io.github.martchus.syncthingtray" -}}
{{-     end -}}
{{-     if not .work -}}
{{-       $_ := set $flatpak_apps "org.openscopeproject.TrguiNG" "org.openscopeproject.TrguiNG" -}}
{{-     end -}}
{{-     if .retro_computing -}}
{{-       $_ := set $flatpak_apps "net._86box._86Box" "net._86box._86Box" -}}
{{-     end -}}
{{-     if .gaming_device_library -}}
{{-       $_ := set $flatpak_apps "org.scummvm.ScummVM" "org.scummvm.ScummVM" -}}
{{-     end -}}
{{-     if .music_library -}}
{{-       $_ := set $flatpak_apps "org.musicbrainz.Picard" "org.musicbrainz.Picard" -}}
{{-     end -}}
{{-     if .ebook_library -}}
{{-       $_ := set $flatpak_apps "com.calibre_ebook.calibre" "com.calibre_ebook.calibre" -}}
{{-     end -}}
{{-     if .video -}}
{{-       $_ := set $flatpak_apps "org.videolan.VLC" "org.videolan.VLC" -}}
{{-     end -}}
{{-     if and .gaming $linux_amd64 -}}
{{-       $_ := set $flatpak_apps "com.valvesoftware.SteamLink" "com.valvesoftware.SteamLink" -}}
{{-     end -}}
{{-   end -}}
{{-   $flatpak_to_install = includeTemplate "packagesForMissingTools" (dict "root" . "packages" $flatpak_apps) | fromJson -}}
{{-   if and (not $zed) (not (eq .osid "linux-chimera")) -}}{{- $need_install = true -}}{{- end -}}
{{-   if and (or (eq .osid "linux-debian") (eq .osid "linux-ubuntu")) (not $kitty) -}}{{- $need_install = true -}}{{- end -}}
{{-   if gt (len $flatpak_to_install) 0 -}}{{- $need_install = true -}}{{- end -}}
{{- end -}}
{{- if and .coding .containers -}}
{{-   $devpod = includeTemplate "find-tool" (dict "root" . "tool" "devpod") -}}
{{-   if not $devpod -}}{{- $need_install = true -}}{{- end -}}
{{- end -}}
{{- if $need_install -}}
#!/usr/bin/env bash

set -euo pipefail

scriptsdir="$CHEZMOI_WORKING_TREE/scripts"
PATH="$scriptsdir:$PATH"

# shellcheck source=./common.sh
. "$scriptsdir/common.sh" || exit 1

{{-   if $flatpak }}
flatpak remote-add --if-not-exists --user flathub https://flathub.org/repo/flathub.flatpakrepo || true
{{-   end }}

{{-   if and (not $zed) (not (eq .osid "linux-chimera")) }}
msg "Installing Zed"
curl -f https://zed.dev/install.sh | sh
{{-   end }}

{{-   range $flatpak_to_install }}
msg "Installing {{ . }} from Flathub"
flatpak install -y --user flathub {{ . }}
{{-   end }}

{{-   if and (or (eq .osid "linux-debian") (eq .osid "linux-ubuntu")) (not $kitty) }}
msg "Installing kitty"
curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin launch=n installer=version-{{ $kitty_version }}
mkdir -p ~/.local/bin ~/.local/share/applications
cp ~/.local/kitty.app/share/applications/kitty.desktop ~/.local/share/applications/ 2>/dev/null
cp ~/.local/kitty.app/share/applications/kitty-open.desktop ~/.local/share/applications/ 2>/dev/null
sed -i "s|Icon=kitty|Icon=$HOME/.local/kitty.app/share/icons/hicolor/256x256/apps/kitty.png|g" ~/.local/share/applications/kitty*.desktop 2>/dev/null
sed -i "s|Exec=kitty|Exec=$HOME/.local/kitty.app/bin/kitty|g" ~/.local/share/applications/kitty*.desktop 2>/dev/null
ln -sf ~/.local/kitty.app/bin/kitty ~/.local/kitty.app/bin/kitten ~/.local/bin/
{{-   end }}

{{-   if and .coding .containers (not $devpod) }}
msg "Installing DevPod CLI"
tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

devpod_arch="amd64"
case "$(uname -m)" in
    aarch64|arm64) devpod_arch="arm64" ;;
esac
curl -L -o "$tmpdir/devpod" "https://github.com/loft-sh/devpod/releases/{{ index .git_lock "distrobox" }}/download/devpod-linux-$devpod_arch"
install -c -m 0755 "$tmpdir/devpod" "$HOME/.local/bin/devpod"
{{-   end }}
{{- end }}
