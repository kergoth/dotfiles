{{- $servers := dict -}}
{{- if .work -}}
{{-   $_ := set $servers "deepwiki" (dict "url" "https://mcp.deepwiki.com/mcp" "type" "http") -}}
{{-   $_ := set $servers "context7" (dict "type" "stdio" "command" "npx" "args" (list "-y" "@upstash/context7-mcp")) -}}
{{-   range $k, $v := (joinPath .chezmoi.workingTree "settings/agents/work-mcp-cursor.json.age" | include | decrypt | fromJson) -}}
{{-     $_ := set $servers $k $v -}}
{{-   end -}}
{{- end -}}
{{- if and .personal (not .ephemeral) -}}
{{-   $_ := set $servers "readwise" (dict "url" "https://mcp2.readwise.io/mcp" "type" "http") -}}
{{-   $_ := set $servers "context7" (dict "type" "stdio" "command" "npx" "args" (list "-y" "@upstash/context7-mcp")) -}}
{{- end -}}
{{- if $servers -}}
{{ dict "mcpServers" $servers | toPrettyJson }}
{{- end -}}
