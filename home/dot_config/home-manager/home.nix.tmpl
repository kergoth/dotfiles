{ config, pkgs, lib, nixpkgs, nixpkgs-unstable, pkgs-unstable, ... }:

let
  modulesDir = ./modules;
  modules =
    builtins.map
      (name: modulesDir + "/${name}")
      (builtins.filter
        (name: lib.hasSuffix ".nix" name)
        (builtins.attrNames (builtins.readDir modulesDir)));

{{- if .work }}
  # Bitdefender SSL inspection re-signs TLS certs with its own CA, which is
  # trusted in macOS Keychain but missing from the Nix CA bundle. Build a
  # combined bundle so Nix-provided curl/wget/etc. can verify connections.
  combinedCaBundle = pkgs.runCommand "combined-ca-bundle" { } ''
    cat ${pkgs.cacert}/etc/ssl/certs/ca-bundle.crt \
        ${./certs/bitdefender-ca-ssl.pem} > $out
  '';
{{- end }}

  isWSL =
    pkgs.stdenv.isLinux
    && builtins.pathExists /proc/sys/fs/binfmt_misc/WSLInterop;

  # Choose the right pinentry program depending on platform.
  pinentry =
    if pkgs.stdenv.isDarwin then pkgs.pinentry_mac
    else if pkgs.stdenv.isLinux && !isWSL then pkgs.pinentry-curses
    else null; # WSL uses Windows pinentry via extraConfig.
in {
  # The home-manager manual is at:
  #
  #   https://rycee.gitlab.io/home-manager/release-notes.html
  #
  # Configuration options are documented at:
  #
  #   https://rycee.gitlab.io/home-manager/options.html

  imports = modules
    ++ lib.optional (builtins.pathExists ./local.nix) ./local.nix;

{{- if .work }}
  # Point Nix tools at the combined CA bundle (Bitdefender SSL inspection)
  home.sessionVariables = {
    NIX_SSL_CERT_FILE = "${combinedCaBundle}";
    SSL_CERT_FILE = "${combinedCaBundle}";
  };
{{- end }}

  home.stateVersion = "25.11";

  home.username = "{{ .chezmoi.username }}";
  home.homeDirectory = "{{ .chezmoi.destDir }}";

  home.packages = with pkgs; [
    wget
    curl
    cacert

    gitFull
    git-lfs
    neovim
    ssh-copy-id
    tmux

    # Development
{{- if .containers }}
    docker
    docker-compose
{{- end }}
    nixpkgs-fmt
    shellcheck

    # Languages
    (python3.withPackages (ps: with ps; [ pip ]))
    nodejs
    uv

    # Core tools
    eza
    choose
    fd
    ripgrep
    zoxide
    sd
    sad
    tealdeer
    unar
    zstd

    # Shell
    bash
    atuin

    # SCM & Related
    delta
    difftastic
    gh
    ghq
    git-absorb
    git-imerge
    git-revise
    patchutils
    jujutsu
  {{- if .work }}
    git-crypt
    google-cloud-sdk
    # Bug tracking and workflow
    jira-cli-go
  {{- end }}

    # Disk and Backup tools
    dua
    duf
    fclones
    restic
    rsync
  {{- if .steamdeck }}
    rclone
  {{- end }}

    # Linting and formatting
    shfmt

    # Nix tools
    nvd

  ] ++ lib.optionals stdenv.isDarwin [
    darwin.trash
    duti
    lima
    mas
    reattach-to-user-namespace
  ] ++ lib.optionals stdenv.isLinux [
    glibcLocales
  {{- if .wsl2 }}
    socat
  {{- end }}
  {{- if and .coding .containers (not .ephemeral) (not .headless) }}
    devpod
  {{- end }}
  ];

  programs = {
    # Let Home Manager install and manage itself.
    home-manager.enable = true;

    # Enable directly supported programs
    direnv.enable = true;
    # direnv.nix-direnv.enable = true;
    fzf.enable = true;
    jq.enable = true;
    bat.enable = true;
{{- if and .containers (not .ephemeral) (eq .chezmoi.os "darwin") }}
    colima.enable = true;
{{- end }}
{{- if not .devpod }}
    # gnupg
    gpg.enable = true;
{{- end }}
  };

{{- if and .work .containers (not .ephemeral) (eq .chezmoi.os "darwin") }}
  # The colima service isn't yet available in the 25.11 home-manager
  #services.colima.enable = true;
{{- end }}
{{- if not .devpod }}
  # Enable gpg-agent with pinentry
  services.gpg-agent = {
    enable = true;
    pinentry.package = pinentry;
    extraConfig = lib.mkIf isWSL ''
      pinentry-program /mnt/c/Program Files (x86)/Gpg4win/bin/pinentry.exe
    '';
    defaultCacheTtl = 3600;
    maxCacheTtl = 72000;
  };
{{- end }}

  nix.registry = {
    nixpkgs.flake = nixpkgs;
    nixpkgs-unstable.flake = nixpkgs-unstable;
  };

  # Disable linking apps into ~/Applications/Home Manager Apps
  targets.darwin.linkApps.enable = false;

  # Future-proof: if/when you bump home.stateVersion so copyApps becomes the default
  targets.darwin.copyApps.enable = false;
}
