{{- $nixarch := .chezmoi.arch -}}
{{- if eq .chezmoi.arch "amd64" -}}
  {{- $nixarch = "x86_64" -}}
{{- else if or (eq .chezmoi.arch "arm64") (eq .chezmoi.arch "aarch64") -}}
  {{- $nixarch = "aarch64" -}}
{{- end -}}
{
  description = "Home Manager configuration of {{ .chezmoi.username }}";

  inputs = {
    # Specify the source of Home Manager and Nixpkgs.
    nixpkgs.url = "github:nixos/nixpkgs/nixos-25.11";
    nixpkgs-unstable.url = "github:nixos/nixpkgs/nixos-unstable";
    home-manager = {
      url = "github:nix-community/home-manager/release-25.11";
      inputs.nixpkgs.follows = "nixpkgs";
    };
  };

  outputs = { nixpkgs, nixpkgs-unstable, home-manager, ... }:
    let
      system = "{{ $nixarch }}-{{ .chezmoi.os }}";
      lib = nixpkgs.lib;

      allowedUnfree = [];
      allowUnfreePredicate = pkg: builtins.elem (lib.getName pkg) allowedUnfree;

      pkgs = import nixpkgs {
        inherit system;
        config.allowUnfreePredicate = allowUnfreePredicate;
      };

      pkgs-unstable = import nixpkgs-unstable {
        inherit system;
        config.allowUnfreePredicate = allowUnfreePredicate;
      };
    in {
      homeConfigurations."{{ .chezmoi.username }}" = home-manager.lib.homeManagerConfiguration {
        inherit pkgs;
        extraSpecialArgs = {
          inherit nixpkgs nixpkgs-unstable pkgs-unstable;
        };

        modules = [ ./home.nix ];
      };
    };
}
