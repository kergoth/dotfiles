{{- $zoxide := includeTemplate "find-tool" (dict "root" . "tool" "zoxide") -}}
{{- $codex := includeTemplate "find-tool" (dict "root" . "tool" "codex") -}}
{{- if and $zoxide $codex -}}
# Interactively select directory via zoxide+fzf and launch codex there.
# Equivalent: zin -i codex ...
# Usage: zicdx [<query>...] [-- <codex-args>...]
_zoxide_run "" 1 0 "{{ $codex }}" "$@"
{{- end -}}
