{{- $zoxide := includeTemplate "find-tool" (dict "root" . "tool" "zoxide") -}}
{{- $claude := includeTemplate "find-tool" (dict "root" . "tool" "claude") -}}
{{- if and $zoxide $claude -}}
# Interactively select directory via zoxide+fzf and launch claude there.
# Equivalent: zin -i claude ...
# Usage: zicl [<query>...] [-- <claude-args>...]
_zoxide_run "" 1 0 "{{ $claude }}" "$@"
{{- end -}}
