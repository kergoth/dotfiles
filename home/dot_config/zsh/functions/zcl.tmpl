{{- $zoxide := includeTemplate "find-tool" (dict "root" . "tool" "zoxide") -}}
{{- $claude := includeTemplate "find-tool" (dict "root" . "tool" "claude") -}}
{{- if and $zoxide $claude -}}
# Resolve directory via zoxide (non-interactive) and launch claude there.
# Equivalent: zin claude ...
# Usage: zcl <query>... [-- <claude-args>...]
_zoxide_run "" 0 0 "{{ $claude }}" "$@"
{{- end -}}
