{{- /* chezmoi:modify-template */ -}}
{{- /* Merge managed Cursor CLI settings into the existing cli-config.json.
       Managed keys (from settings/cursor/cli-config.json) override; all other
       keys (permissions, model, authInfo, serverConfigCache, privacyCache,
       etc.) are preserved. mergeOverwrite does recursive object merge. */ -}}
{{- $managed := joinPath .chezmoi.workingTree "settings/cursor/cli-config.json" | include | fromJson -}}
{{- if eq .chezmoi.stdin "" -}}
{{-   $managed | toPrettyJson -}}
{{- else -}}
{{-   $existing := fromJson .chezmoi.stdin -}}
{{-   $merged := mergeOverwrite $existing $managed -}}
{{-   $merged | toPrettyJson -}}
{{- end -}}
