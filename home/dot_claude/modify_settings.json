{{- /* chezmoi:modify-template */ -}}
{{- /* Merge managed Claude Code settings into the existing settings.json.
       Managed keys (from settings/claude/settings.json) override; all other
       keys (enabledPlugins, permissions, extraKnownMarketplaces, etc.) are
       preserved. mergeOverwrite does recursive object merge.

       Special handling for arrays that should be concatenated rather than
       replaced: permissions.allow, permissions.deny, sandbox.excludedCommands,
       and sandbox.network.allowedDomains. We extract them before the merge,
       then concat+uniq and patch them back. */ -}}
{{- $managed := includeTemplate (joinPath .chezmoi.workingTree "settings/claude/settings.json.tmpl") . | fromJson -}}
{{- if eq .chezmoi.stdin "" -}}
{{-   $managed | toPrettyJson -}}
{{- else -}}
{{-   $existing := fromJson .chezmoi.stdin -}}
{{- /* Extract arrays before the object merge clobbers them */ -}}
{{-   $existingAllow := dig "permissions" "allow" (list) $existing -}}
{{-   $managedAllow := dig "permissions" "allow" (list) $managed -}}
{{-   $existingDeny := dig "permissions" "deny" (list) $existing -}}
{{-   $managedDeny := dig "permissions" "deny" (list) $managed -}}
{{-   $existingExcluded := dig "sandbox" "excludedCommands" (list) $existing -}}
{{-   $managedExcluded := dig "sandbox" "excludedCommands" (list) $managed -}}
{{-   $existingAllowWrite := dig "sandbox" "filesystem" "allowWrite" (list) $existing -}}
{{-   $managedAllowWrite := dig "sandbox" "filesystem" "allowWrite" (list) $managed -}}
{{-   $existingDenyWrite := dig "sandbox" "filesystem" "denyWrite" (list) $existing -}}
{{-   $managedDenyWrite := dig "sandbox" "filesystem" "denyWrite" (list) $managed -}}
{{-   $existingAllowRead := dig "sandbox" "filesystem" "allowRead" (list) $existing -}}
{{-   $managedAllowRead := dig "sandbox" "filesystem" "allowRead" (list) $managed -}}
{{-   $existingDenyRead := dig "sandbox" "filesystem" "denyRead" (list) $existing -}}
{{-   $managedDenyRead := dig "sandbox" "filesystem" "denyRead" (list) $managed -}}
{{-   $existingDomains := dig "sandbox" "network" "allowedDomains" (list) $existing -}}
{{-   $managedDomains := dig "sandbox" "network" "allowedDomains" (list) $managed -}}
{{-   $merged := mergeOverwrite $existing $managed -}}
{{- /* Concat and deduplicate arrays */ -}}
{{-   $mergedAllow := concat $existingAllow $managedAllow | uniq -}}
{{-   $mergedDeny := concat $existingDeny $managedDeny | uniq -}}
{{-   $mergedExcluded := concat $existingExcluded $managedExcluded | uniq -}}
{{-   $mergedAllowWrite := concat $existingAllowWrite $managedAllowWrite | uniq -}}
{{-   $mergedDenyWrite := concat $existingDenyWrite $managedDenyWrite | uniq -}}
{{-   $mergedAllowRead := concat $existingAllowRead $managedAllowRead | uniq -}}
{{-   $mergedDenyRead := concat $existingDenyRead $managedDenyRead | uniq -}}
{{-   $mergedDomains := concat $existingDomains $managedDomains | uniq -}}
{{- /* Ensure permissions object exists, then patch arrays back in */ -}}
{{-   if not (hasKey $merged "permissions") -}}
{{-     $_ := set $merged "permissions" dict -}}
{{-   end -}}
{{-   if $mergedAllow -}}
{{-     $_ := set $merged.permissions "allow" $mergedAllow -}}
{{-   else -}}
{{-     $_ := unset $merged.permissions "allow" -}}
{{-   end -}}
{{-   if $mergedDeny -}}
{{-     $_ := set $merged.permissions "deny" $mergedDeny -}}
{{-   else -}}
{{-     $_ := unset $merged.permissions "deny" -}}
{{-   end -}}
{{- /* Ensure sandbox object exists, then patch arrays back in */ -}}
{{-   if not (hasKey $merged "sandbox") -}}
{{-     $_ := set $merged "sandbox" dict -}}
{{-   end -}}
{{-   if $mergedExcluded -}}
{{-     $_ := set $merged.sandbox "excludedCommands" $mergedExcluded -}}
{{-   else -}}
{{-     $_ := unset $merged.sandbox "excludedCommands" -}}
{{-   end -}}
{{-   if $mergedAllowWrite -}}
{{-     if not (hasKey $merged.sandbox "filesystem") -}}
{{-       $_ := set $merged.sandbox "filesystem" dict -}}
{{-     end -}}
{{-     $_ := set $merged.sandbox.filesystem "allowWrite" $mergedAllowWrite -}}
{{-   else if hasKey $merged.sandbox "filesystem" -}}
{{-     $_ := unset $merged.sandbox.filesystem "allowWrite" -}}
{{-   end -}}
{{-   if $mergedDenyWrite -}}
{{-     if not (hasKey $merged.sandbox "filesystem") -}}
{{-       $_ := set $merged.sandbox "filesystem" dict -}}
{{-     end -}}
{{-     $_ := set $merged.sandbox.filesystem "denyWrite" $mergedDenyWrite -}}
{{-   else if hasKey $merged.sandbox "filesystem" -}}
{{-     $_ := unset $merged.sandbox.filesystem "denyWrite" -}}
{{-   end -}}
{{-   if $mergedAllowRead -}}
{{-     if not (hasKey $merged.sandbox "filesystem") -}}
{{-       $_ := set $merged.sandbox "filesystem" dict -}}
{{-     end -}}
{{-     $_ := set $merged.sandbox.filesystem "allowRead" $mergedAllowRead -}}
{{-   else if hasKey $merged.sandbox "filesystem" -}}
{{-     $_ := unset $merged.sandbox.filesystem "allowRead" -}}
{{-   end -}}
{{-   if $mergedDenyRead -}}
{{-     if not (hasKey $merged.sandbox "filesystem") -}}
{{-       $_ := set $merged.sandbox "filesystem" dict -}}
{{-     end -}}
{{-     $_ := set $merged.sandbox.filesystem "denyRead" $mergedDenyRead -}}
{{-   else if hasKey $merged.sandbox "filesystem" -}}
{{-     $_ := unset $merged.sandbox.filesystem "denyRead" -}}
{{-   end -}}
{{-   if $mergedDomains -}}
{{-     if not (hasKey $merged.sandbox "network") -}}
{{-       $_ := set $merged.sandbox "network" dict -}}
{{-     end -}}
{{-     $_ := set $merged.sandbox.network "allowedDomains" $mergedDomains -}}
{{-   else if hasKey $merged.sandbox "network" -}}
{{-     $_ := unset $merged.sandbox.network "allowedDomains" -}}
{{-   end -}}
{{-   $merged | toPrettyJson -}}
{{- end -}}
