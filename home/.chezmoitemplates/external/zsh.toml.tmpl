{{- $lock := .externals_lock -}}
{{- $binpath := ".local/bin" -}}
{{- if eq .chezmoi.os "windows" -}}
{{-   $binpath = "AppData/Local/Programs/bin" -}}
{{- end -}}
{{- $zsh_completions_version := (gitHubLatestRelease "zsh-users/zsh-completions").TagName }}
{{- $fzf_tab_version := (gitHubLatestRelease "Aloxaf/fzf-tab").TagName }}
{{- $history_search_version := (gitHubLatestRelease "zsh-users/zsh-history-substring-search").TagName }}
{{- $nix_shell_version := (gitHubLatestRelease "chisui/zsh-nix-shell").TagName }}
{{- $nix_completions_version := (gitHubLatestRelease "nix-community/nix-zsh-completions").TagName }}
{{- $powerlevel10k_version := (gitHubLatestRelease "romkatv/powerlevel10k").TagName }}

[".config/zsh/functions/manydots-magic"]
type = "file"
url = {{ printf "https://raw.githubusercontent.com/knu/zsh-manydots-magic/%s/manydots-magic" (index $lock "knu_zsh_manydots_magic") | toToml }}

[".config/zsh/functions/git-escape-magic"]
type = "file"
url = {{ printf "https://raw.githubusercontent.com/knu/zsh-git-escape-magic/%s/git-escape-magic" (index $lock "knu_zsh_git_escape_magic") | toToml }}

[".config/zsh/plugins/autosuggestions"]
type = "archive"
url = {{ printf "https://github.com/zsh-users/zsh-autosuggestions/archive/%s.tar.gz" (index $lock "zsh_autosuggestions") | toToml }}
exact = true
stripComponents = 1

[".config/zsh/plugins/bd"]
type = "archive"
url = {{ printf "https://github.com/Tarrasch/zsh-bd/archive/%s.tar.gz" (index $lock "zsh_bd") | toToml }}
exact = true
stripComponents = 1

[".config/zsh/plugins/completions"]
type = "archive"
url = "https://github.com/zsh-users/zsh-completions/archive/refs/tags/{{ $zsh_completions_version }}.tar.gz"
exact = true
stripComponents = 1

[".config/zsh/plugins/fzf-tab"]
type = "archive"
url = "https://github.com/Aloxaf/fzf-tab/archive/refs/tags/{{ $fzf_tab_version }}.tar.gz"
exact = true
stripComponents = 1

[".config/zsh/plugins/history-substring-search"]
type = "archive"
url = "https://github.com/zsh-users/zsh-history-substring-search/archive/refs/tags/{{ $history_search_version }}.tar.gz"
exact = true
stripComponents = 1

[".config/zsh/plugins/nix-shell"]
type = "archive"
url = "https://github.com/chisui/zsh-nix-shell/archive/refs/tags/{{ $nix_shell_version }}.tar.gz"
exact = true
stripComponents = 1

[".config/zsh/plugins/nix-zsh-completions"]
type = "archive"
url = "https://github.com/nix-community/nix-zsh-completions/archive/refs/tags/{{ $nix_completions_version }}.tar.gz"
exact = true
stripComponents = 1

[".config/zsh/plugins/syntax-highlighting"]
type = "archive"
url = {{ printf "https://github.com/zsh-users/zsh-syntax-highlighting/archive/%s.tar.gz" (index $lock "zsh_syntax_highlighting") | toToml }}
exact = true
stripComponents = 1

{{ if .wsl2 -}}
[".config/zsh/plugins/windows-terminal-zsh-integration"]
type = "archive"
url = {{ printf "https://github.com/romkatv/windows-terminal-zsh-integration/archive/%s.tar.gz" (index $lock "zsh_windows_terminal_integration") | toToml }}
exact = true
stripComponents = 1
{{- end }}

[".config/zsh/plugins/zbell/zbell.plugin.sh"]
type = "file"
url = "https://gist.githubusercontent.com/jpouellet/5278239/raw/e0b06247f3ecd6ca3de341c54ba8d85de7ef6566/zbell.sh"
refreshPeriod = "{{ .external.refreshPeriod }}"

[".config/zsh/themes/powerlevel10k"]
type = "archive"
url = "https://github.com/romkatv/powerlevel10k/archive/refs/tags/{{ $powerlevel10k_version }}.tar.gz"
exact = true
stripComponents = 1

[".local/bin/zsh_sort_timings"]
type = "file"
url = "https://gist.githubusercontent.com/bdesham/2d7ef99f93b226be29e01cadcad37405/raw/353e5178686df9e3aea6e0802d4a217420938c28/sort_timings.zsh"
executable = true
