url = {{ printf "https://github.com/chisui/zsh-nix-shell/archive/refs/tags/%s.tar.gz" (index $lock "zsh_nix_shell") | toToml }}
exact = true
stripComponents = 1

[".config/zsh/plugins/nix-zsh-completions"]
