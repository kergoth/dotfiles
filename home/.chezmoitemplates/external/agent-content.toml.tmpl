stripComponents = 1

[".agents/external-sources/astral"]
type = "archive"
url = {{ printf "https://github.com/astral-sh/claude-code-plugins/archive/%s.tar.gz" (index $lock "astral") | toToml }}
exact = true
stripComponents = 1
