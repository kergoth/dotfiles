{{- $lock := .externals_lock -}}

[".agents/external-sources/anthropic_official_plugins"]
type = "archive"
url = {{ printf "https://github.com/anthropics/claude-plugins-official/archive/%s.tar.gz" (index $lock "anthropic_official_plugins") | toToml }}
exact = true
stripComponents = 1

[".agents/external-sources/superpowers"]
