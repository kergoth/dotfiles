{{ $refreshPeriod := .external.refreshPeriod }}
{{- $lock := .externals_lock -}}
{{ $clone_args := dig "external" "clone" "args" (list) . -}}
{{ $pull_args := dig "external" "pull" "args" (list) . -}}

["bin"]
    type = "git-repo"
    url = "https://github.com/kergoth/scripts"
    refreshPeriod = "24h"
    [bin.clone]
    args = {{ $clone_args | toToml }}
    [bin.pull]
    args = {{ $pull_args | toToml }}

{{- if and .secrets .personal (not .ephemeral) (ne .chezmoi.os "windows") }}
[".config/backup"]
    type = "git-repo"
    url = "git@github.com:kergoth/backup-conductor.git"
    refreshPeriod = "24h"
    [".config/backup".clone]
    args = {{ $clone_args | toToml }}
    [".config/backup".pull]
    args = {{ $pull_args | toToml }}
{{- end }}

{{ $bat_extras_version := (gitHubLatestRelease "eth-p/bat-extras").TagName | trimPrefix "v" }}
{{ $splitver := $bat_extras_version | splitList "." }}
{{ range list "batdiff" "batgrep" "batman" "bat-modules" "batpipe" "batwatch" -}}
[".local/bin/{{ . }}"]
type = "archive-file"
url = "https://github.com/eth-p/bat-extras/releases/download/v{{- $bat_extras_version -}}/bat-extras-{{- index $splitver 0 -}}.{{- index $splitver 1 -}}.{{- index $splitver 2 -}}.zip"
path = "{{ . }}"
stripComponents = 1
executable = true
{{ end }}

[".local/bin/git-j"]
type = "archive-file"
url = {{ printf "https://github.com/beanbaginc/dev-goodies/archive/%s.tar.gz" (index $lock "beanbaginc_dev_goodies") | toToml }}
path = "bin/git-j"
exact = true
stripComponents = 1

[".local/bin/git-rebase-chain"]
type = "archive-file"
url = {{ printf "https://github.com/beanbaginc/dev-goodies/archive/%s.tar.gz" (index $lock "beanbaginc_dev_goodies") | toToml }}
path = "bin/git-rebase-chain"
exact = true
stripComponents = 1

{{- $gitextras_version := (gitHubLatestRelease "tj/git-extras").TagName }}
[".local/bin/git-alias"]
type = "archive-file"
url = "https://github.com/tj/git-extras/archive/refs/tags/{{ $gitextras_version }}.tar.gz"
path = "bin/git-alias"
exact = true
stripComponents = 1

[".local/bin/linux-bundle-clone"]
type = "file"
url = {{ printf "https://git.kernel.org/pub/scm/linux/kernel/git/mricon/korg-helpers.git/plain/linux-bundle-clone?id=%s" (index $lock "korg_helpers") | toToml }}
executable = true

[".local/bin/vipe"]
type = "archive-file"
url = {{ printf "https://github.com/madx/moreutils/archive/%s.tar.gz" (index $lock "madx_moreutils") | toToml }}
path = "vipe"
exact = true
stripComponents = 1

[".local/bin/wsl-open"]
type = "file"
url = {{ printf "https://raw.githubusercontent.com/4U6U57/wsl-open/%s/wsl-open.sh" (index $lock "wsl_open") | toToml }}
executable = true

[".local/bin/ifne"]
type = "archive-file"
url = {{ printf "https://github.com/fumiyas/home-commands/archive/%s.tar.gz" (index $lock "fumiyas_home_commands") | toToml }}
path = "ifne"
executable = true
exact = true
stripComponents = 1

[".local/bin/git-assembler"]
type = "archive-file"
url = {{ printf "https://gitlab.com/wavexx/git-assembler/-/archive/%s/git-assembler-%s.tar.gz" (index $lock "git_assembler") (index $lock "git_assembler") | toToml }}
path = "git-assembler"
exact = true
stripComponents = 1

[".local/bin/git-attic"]
type = "file"
url = "https://chneukirchen.org/dotfiles/bin/git-attic"
executable = true
refreshPeriod = "{{ $refreshPeriod }}"
