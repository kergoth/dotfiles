{{-   $uses_musl := false -}}
{{-   $has_git_bash := false -}}
{{-   $bash := "" -}}
{{-   if ne .chezmoi.os "windows" -}}
{{-     if exec "sh" "-c" "ldd --version 2>&1 | grep -qi musl" -}}
{{-       $uses_musl = true -}}
{{-     end -}}
{{-   else -}}
{{-     $userprofile := .env.USERPROFILE | default "" -}}
{{-     $bash = joinPath $userprofile "scoop" "apps" "git" "current" "bin" "bash.exe" -}}
{{-     if and $userprofile (stat $bash) -}}
{{-       $has_git_bash = true -}}
{{-     end -}}
{{-   end -}}
{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING" : "0",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT" : "0",
    "ANTHROPIC_DEFAULT_OPUS_MODEL" : "claude-opus-4-6",
    "DISABLE_AUTOUPDATER": "1"{{ if $uses_musl }},
    "USE_BUILTIN_RIPGREP": "0"{{ end }}{{ if $has_git_bash }},
    "CLAUDE_CODE_GIT_BASH_PATH": "{{ replace $bash `\` `\\` }}"{{ end }}
  },
  "permissions": {
    "allow": [
      "Bash(python ~/.claude/skills/find-session/scripts/search_sessions.py:*)",
      "Skill(superpowers:*)",
      "Skill(clean-prose *)",
      "Skill(cli-design *)",
      "Skill(cram *)",
      "Skill(dispatch-external-model *)",
      "Skill(evaluate-open-source-project *)",
      "Skill(find-session *)",
      "Skill(find-skills *)",
      "Skill(git-commits *)",
      "Skill(git-prs *)",
      "Skill(github-issue-triage *)",
      "Skill(issue-tracking-conventions *)",
      "Skill(jj-commits *)",
      "Skill(jujutsu *)",
      "Skill(obsidian-cli *)",
      "Skill(shell-script-style *)",
      "Skill(brainstorming *)",
      "Skill(dispatching-parallel-agents *)",
      "Skill(executing-plans *)",
      "Skill(finishing-a-development-branch *)",
      "Skill(receiving-code-review *)",
      "Skill(requesting-code-review *)",
      "Skill(subagent-driven-development *)",
      "Skill(systematic-debugging *)",
      "Skill(test-driven-development *)",
      "Skill(using-git-worktrees *)",
      "Skill(using-superpowers *)",
      "Skill(verification-before-completion *)",
      "Skill(writing-plans *)",
      "Skill(writing-skills *)",
      "Skill(uv *)",
      "Skill(ty *)",
      "Skill(ruff *)",
      "Skill(gh-pr-review *)",
      "Skill(avoid-ai-writing *)",
      "Read(~/.agents/skills/**/references/**)"
    ]
  },
  "outputStyle": "Direct Explanatory",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "gh *",
      "gcloud *"
    ],
    "filesystem": {
      "allowWrite": [
        "~/.cache/uv",
        "~/Library/Caches/uv"
      ]
    },
    "network": {
      "allowedDomains": [
        "api.github.com",
        "raw.githubusercontent.com"
      ]
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
