{{-   $uses_musl := false -}}
{{-   if ne .chezmoi.os "windows" -}}
{{-     if exec "sh" "-c" "ldd --version 2>&1 | grep -qi musl" -}}
{{-       $uses_musl = true -}}
{{-     end -}}
{{-   end -}}
{
  "model": "opus[1m]",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1"{{ if $uses_musl }},
    "USE_BUILTIN_RIPGREP": "0"{{ end }}
  }
}
