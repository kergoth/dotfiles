{{-   $uses_musl := false -}}
{{-   $has_git_bash := false -}}
{{-   $bash := "" -}}
{{-   if ne .chezmoi.os "windows" -}}
{{-     if exec "sh" "-c" "ldd --version 2>&1 | grep -qi musl" -}}
{{-       $uses_musl = true -}}
{{-     end -}}
{{-   else -}}
{{-     $userprofile := .env.USERPROFILE | default "" -}}
{{-     $bash = joinPath $userprofile "scoop" "apps" "git" "current" "bin" "bash.exe" -}}
{{-     if and $userprofile (stat $bash) -}}
{{-       $has_git_bash = true -}}
{{-     end -}}
{{-   end -}}
{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING" : "0",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT" : "0",
    "ANTHROPIC_DEFAULT_OPUS_MODEL" : "claude-opus-4-6",
    "DISABLE_AUTOUPDATER": "1"{{ if $uses_musl }},
    "USE_BUILTIN_RIPGREP": "0"{{ end }}{{ if $has_git_bash }},
    "CLAUDE_CODE_GIT_BASH_PATH": "{{ replace $bash `\` `\\` }}"{{ end }}
  },
  "permissions": {
    "allow": [
      "Bash(python ~/.claude/skills/find-session/scripts/search_sessions.py:*)"
    ]
  },
  "outputStyle": "Direct Explanatory",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "gh *",
      "gcloud *"
    ],
    "filesystem": {
      "allowWrite": [
        "~/.cache/uv",
        "~/Library/Caches/uv"
      ]
    },
    "network": {
      "allowedDomains": [
        "api.github.com",
        "raw.githubusercontent.com"
      ]
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
