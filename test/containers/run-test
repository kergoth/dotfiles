#!/bin/sh
# Usage: run-test [options] [DISTRO]
#
# Env overrides:
#     ARCH_BASE_IMAGE         Override base image for arch container (all arches).
#     ARCH_ARM64_BASE_IMAGE   Override base image for arch container on arm64 only.
#                             Default: ghcr.io/baerenbude-org/archlinuxarm-arm64v8:latest
#
# Build and run a test container to validate dotfiles setup scripts.
#
# Distros:
#     arch, chimera, debian, fedora, ubuntu
#
# Options:
#     -a          Run for all distros (auto-detected from Dockerfiles)
#     -i          Drop into a root shell before setup
#     -s          Drop into a user shell after setup
#     -S          Skip setup-system, only run setup
#     -b          Just build the image(s), don't run
#     -n          Dry run, don't actually do anything
#     -v          Increase verbosity, can be specified multiple times
#     -q          Decrease verbosity, can be specified multiple times
#     -h          Show this help message

set -eu

usage() {
    show_help >&2
    exit "${1:-1}"
}

process_arguments() {
    all_distros=0
    interactive=0
    shell_after=0
    no_system=0
    build_only=0
    dry_run=0
    verbosity=0

    distro=

    user=testuser
    dotfiles_mount=/home/testuser/.dotfiles

    while getopts ":aisSbnvqh" opt; do
        case "$opt" in
            a)
                all_distros=1
                ;;
            i)
                interactive=1
                ;;
            s)
                shell_after=1
                ;;
            S)
                no_system=1
                ;;
            b)
                build_only=1
                ;;
            n)
                dry_run=1
                ;;
            v)
                verbosity=$((verbosity + 1))
                ;;
            q)
                verbosity=$((verbosity - 1))
                ;;
            h)
                usage 0
                ;;
            \?)
                msg "Unknown option: -%s" "$OPTARG"
                usage 1
                ;;
        esac
    done
    shift $((OPTIND - 1))

    if [ "$all_distros" -eq 1 ]; then
        if [ $# -gt 0 ]; then
            msg "Unexpected argument with -a: %s" "$1"
            usage 1
        fi
        if [ "$interactive" -eq 1 ] || [ "$shell_after" -eq 1 ]; then
            msg "-a cannot be combined with -i or -s"
            usage 1
        fi
        return 0
    fi

    if [ $# -lt 1 ]; then
        msg "Error: distro argument required (or use -a)"
        usage 1
    fi
    if [ $# -gt 1 ]; then
        msg "Unexpected argument: %s" "$2"
        usage 1
    fi

    distro=$1
}

show_help() {
    sed -n '/^# Usage:/,/^# *-h /p' "$0" | sed 's/^# *//'
}

msg() {
    fmt=$1
    if [ $# -gt 1 ]; then
        shift
    fi
    # shellcheck disable=SC2059
    printf "$fmt\n" "$@" >&2
}

die() {
    fmt=$1
    shift || true
    # shellcheck disable=SC2059
    printf "Error: $fmt\n" "$@" >&2
    exit 1
}

printcmd() {
    out=
    sep=
    for arg in "$@"; do
        case "$arg" in
            *[!A-Za-z0-9_./:-]*|'')
                arg=$(printf "%s" "$arg" | sed "s/'/'\\\\''/g")
                arg="'$arg'"
                ;;
        esac
        out="${out}${sep}${arg}"
        sep=" "
    done
    printf "%s" "$out"
}

run() {
    if [ "${dry_run:-0}" -eq 1 ] || [ "${verbosity:-0}" -gt 0 ]; then
        printf '❯ %s\n' "$(printcmd "$@")" >&2
    fi
    if [ "${dry_run:-0}" -ne 1 ]; then
        "$@"
    fi
}

find_distros() {
    for d in "$scriptdir"/*; do
        [ -d "$d" ] || continue
        [ -f "$d/Dockerfile" ] || continue
        printf "%s\n" "${d##*/}"
    done
}

validate_distro() {
    if [ ! -f "$scriptdir/$1/Dockerfile" ]; then
        die "no test container for '%s' (expected %s/%s/Dockerfile)" "$1" "$scriptdir" "$1"
    fi
}

docker_server_arch() {
    # Prefer docker version formatting (fast, stable), fall back to docker info.
    arch=$(docker version -f '{{.Server.Arch}}' 2>/dev/null || true)
    if [ -n "$arch" ]; then
        printf "%s" "$arch"
        return 0
    fi
    arch=$(docker info -f '{{.Architecture}}' 2>/dev/null || true)
    if [ -n "$arch" ]; then
        printf "%s" "$arch"
        return 0
    fi
    # Unknown; let docker decide.
    printf "%s" "unknown"
}

arch_base_image_for_host() {
    if [ -n "${ARCH_BASE_IMAGE:-}" ]; then
        printf "%s" "$ARCH_BASE_IMAGE"
        return 0
    fi
    if [ "$(docker_server_arch)" = "arm64" ]; then
        printf "%s" "${ARCH_ARM64_BASE_IMAGE:-ghcr.io/baerenbude-org/archlinuxarm-arm64v8:latest}"
        return 0
    fi
    printf "%s" "archlinux/archlinux:latest"
}

emit_container_script() {
    setup_cmd=$1
    GITHUB_TOKEN=${GITHUB_TOKEN:-}

    # shellcheck disable=SC2016
    cat <<EOF
#!/bin/sh
set -eu

cd "$dotfiles_mount"

script/$distro/setup-root "$user" </dev/null

chown "$user" "/home/$user"
chown -R "$user" "$dotfiles_mount"

export DOTFILES_DIR="$dotfiles_mount"

if command -v su >/dev/null 2>&1; then
    su - "$user" -c "set -x; export DOTFILES_DIR='$dotfiles_mount' GITHUB_TOKEN='$GITHUB_TOKEN'; cd '$dotfiles_mount' && './$setup_cmd' </dev/null"
elif command -v doas >/dev/null 2>&1; then
    doas -u "$user" sh -c "set -x; export DOTFILES_DIR='$dotfiles_mount' GITHUB_TOKEN='$GITHUB_TOKEN'; cd '$dotfiles_mount' && './$setup_cmd' </dev/null"
else
    echo "Error: need su or doas in container to run as user" >&2
    exit 1
fi
echo >&2 "$distro test complete."

if [ "\${SHELL_AFTER:-0}" -eq 1 ]; then
    echo "Setup complete. Dropping into user shell..." >&2
    if command -v su >/dev/null 2>&1; then
        exec su - "$user" -c "exec zsh --login"
    elif command -v doas >/dev/null 2>&1; then
        exec doas -u "$user" zsh --login
    fi
fi
EOF
}

build_image() {
    image_name=$1
    build_context=$2
    distro=$3

    msg "Building %s..." "$image_name"
    if [ "${distro:-}" = "arch" ]; then
        base_image=$(arch_base_image_for_host)
        msg "  arch base image: %s" "$base_image"
        DOCKER_BUILDKIT=0 run docker build \
            --build-arg "BASE_IMAGE=$base_image" \
            -t "$image_name" \
            "$build_context"
    else
        run docker build -t "$image_name" "$build_context"
    fi
}

run_container() {
    image_name=$1

    if [ "$no_system" -eq 1 ]; then
        setup_cmd="script/setup"
    else
        setup_cmd="script/setup-full"
    fi

    set -- \
        --rm \
        -v "$repodir:$dotfiles_mount" \
        -e NO_USER_PASSWORD=1 \
        ${GITHUB_TOKEN:+-e GITHUB_TOKEN="$GITHUB_TOKEN"}

    if [ "$interactive" -eq 1 ]; then
        msg "Dropping into interactive root shell..."
        msg "  Dotfiles repo is at %s" "$dotfiles_mount"
        run docker run --entrypoint /bin/sh -it "$@" "$image_name"
        return 0
    fi

    emit_container_script "$setup_cmd" >"$tmpdir/run-test"
    chmod +x "$tmpdir/run-test"

    if [ "$shell_after" -eq 1 ]; then
        run docker run --entrypoint /bin/sh -it -e SHELL_AFTER=1 \
            -v "$tmpdir/run-test:/tmp/run-test:ro" \
            "$@" "$image_name" /tmp/run-test
    else
        run docker run --entrypoint /bin/sh -i \
            -v "$tmpdir/run-test:/tmp/run-test:ro" \
            "$@" "$image_name" /tmp/run-test
    fi
}

run_one() {
    distro=$1
    image_name="dotfiles-test-$distro"
    build_context="$scriptdir/$distro/"

    validate_distro "$distro"
    build_image "$image_name" "$build_context" "$distro"

    if [ "$build_only" -eq 1 ]; then
        msg "Image %s built successfully." "$image_name"
        return 0
    fi

    run_container "$image_name"
}

main() {
    process_arguments "$@"
    tmpdir=$(mktemp -d "$HOME/.tmp.run-test.XXXXXX")
    trap 'rm -rf "$tmpdir"' EXIT INT TERM

    if [ "$all_distros" -eq 1 ]; then
        distros=$(find_distros)
        if [ -z "$distros" ]; then
            die "no distros found under %s (expected */Dockerfile)" "$scriptdir"
        fi

        echo "$distros" | while IFS= read -r d; do
            [ -n "$d" ] || continue
            run_one "$d"
        done
        echo >&2 "All tests completed."

        return 0
    fi

    run_one "$distro"
}

if [ -z "${0##/*}" ]; then
    scriptdir=$(cd "$(dirname "$0")" && pwd -P)
else
    script=$(command -v "${0##*/}") || script="$0"
    scriptdir=$(cd "$(dirname "$script")" && pwd -P)
fi

repodir=$(cd "$scriptdir/../.." && pwd -P)

main "$@"
