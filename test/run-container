#!/bin/sh
# Usage: run-test [options] [DISTRO]
#
# Env overrides:
#     ARCH_BASE_IMAGE         Override base image for arch container (all arches).
#     ARCH_ARM64_BASE_IMAGE   Override base image for arch container on arm64 only.
#                             Default: ghcr.io/baerenbude-org/archlinuxarm-arm64v8:latest
#     DOTFILES_SKIP_GPG_SECRET_IMPORT  Skip secret key import in GPG setup (1/0).
#     DOTFILES_SECRETS        Force secrets on/off (1/0).
#     DOTFILES_PERSONAL       Force personal profile (always passed through).
#     DOTFILES_WORK           Force work profile (always passed through).
#
# Build and run a test container to validate dotfiles setup scripts.
#
# Distros:
#     arch, chimera, debian, fedora, ubuntu
#
# Options:
#     -a          Run for all distros (auto-detected from Dockerfiles)
#     -i          Preserve stdin/TTY for interactive setup prompts
#     -s          Drop into a user shell after the selected setup phase
#     -r          Stop after setup-root (skip setup/setup-full)
#     -S          Skip setup-system, only run setup
#     -c CMD      Run CMD as the test user after the selected setup phase
#     -b          Just build the image(s), don't run
#     -w          Workstation mode (DOTFILES_HEADLESS=0, DOTFILES_EPHEMERAL=0)
#     -G          Seed GNUPGHOME from host (~/.gnupg) for test user
#     -C          Skip shared nix cache
#     -n          Dry run, don't actually do anything
#     -v          Increase verbosity, can be specified multiple times
#     -q          Decrease verbosity, can be specified multiple times
#     -h          Show this help message

set -eu

usage() {
    show_help >&2
    exit "${1:-1}"
}

process_arguments() {
    all_distros=0
    setup_mode=full
    saw_root_only=0
    saw_user_only=0
    action=run
    interactive=0
    command=
    build_only=0
    with_gnupg=0
    skip_nix_cache=${DOTFILES_SKIP_CACHE:-0}
    dry_run=0
    verbosity=0

    distro=

    user=testuser
    user_uid=10000
    dotfiles_mount=/home/testuser/.dotfiles

    while getopts ":aisSbc:rwCnvqhG" opt; do
        case "$opt" in
            a)
                all_distros=1
                ;;
            i)
                interactive=1
                ;;
            s)
                action=shell
                ;;
            S)
                setup_mode=user-only
                saw_user_only=1
                ;;
            b)
                build_only=1
                ;;
            c)
                action=command
                command=$OPTARG
                ;;
            r)
                setup_mode=root-only
                saw_root_only=1
                ;;
            w)
                DOTFILES_HEADLESS=0
                DOTFILES_EPHEMERAL=0
                ;;
            G)
                with_gnupg=1
                ;;
            C)
                skip_nix_cache=1
                ;;
            n)
                dry_run=1
                ;;
            v)
                verbosity=$((verbosity + 1))
                ;;
            q)
                verbosity=$((verbosity - 1))
                ;;
            h)
                usage 0
                ;;
            \?)
                msg "Unknown option: -%s" "$OPTARG"
                usage 1
                ;;
        esac
    done
    shift $((OPTIND - 1))

    if [ "$all_distros" -eq 1 ]; then
        if [ $# -gt 0 ]; then
            msg "Error: Unexpected argument with -a: %s" "$1"
            usage 1
        fi
        if [ "$action" != "run" ] || [ "$interactive" -eq 1 ]; then
            msg "Error: -a cannot be combined with -i, -s, or -c"
            usage 1
        fi
        return 0
    fi

    if [ "$saw_root_only" -eq 1 ] && [ "$saw_user_only" -eq 1 ]; then
        msg "Error: -r cannot be combined with -S"
        usage 1
    fi

    if [ $# -lt 1 ]; then
        msg "Error: distro argument required (or use -a)"
        usage 1
    fi
    if [ $# -gt 1 ] && { [ "$action" != "run" ] || [ "$interactive" -eq 1 ]; }; then
        msg "Error: Multiple distros cannot be combined with -i, -s, or -c"
        usage 1
    fi
}

show_help() {
    sed -n '/^# Usage:/,/^# *-h /p' "$0" | sed 's/^# *//'
}

msg() {
    fmt=$1
    if [ $# -gt 1 ]; then
        shift
    fi
    # shellcheck disable=SC2059
    printf "$fmt\n" "$@" >&2
}

die() {
    fmt=$1
    shift || true
    # shellcheck disable=SC2059
    printf "Error: $fmt\n" "$@" >&2
    exit 1
}

printcmd() {
    out=
    sep=
    for arg in "$@"; do
        case "$arg" in
            *[!A-Za-z0-9_./:-]*|'')
                arg=$(printf "%s" "$arg" | sed "s/'/'\\\\''/g")
                arg="'$arg'"
                ;;
        esac
        out="${out}${sep}${arg}"
        sep=" "
    done
    printf "%s" "$out"
}

run() {
    if [ "${dry_run:-0}" -eq 1 ] || [ "${verbosity:-0}" -gt 0 ]; then
        printf '❯ %s\n' "$(printcmd "$@")" >&2
    fi
    if [ "${dry_run:-0}" -ne 1 ]; then
        "$@"
    fi
}

is_truthy() {
    case "$(printf "%s" "${1:-}" | tr '[:upper:]' '[:lower:]')" in
        1|true|yes|on) return 0 ;;
    esac
    return 1
}

resolve_host_profile() {
    if [ -n "${DOTFILES_PERSONAL:-}" ] || [ -n "${DOTFILES_WORK:-}" ]; then
        return 0
    fi
    if ! command -v chezmoi >/dev/null 2>&1; then
        return 0
    fi

    host_profile=$(chezmoi execute-template --no-tty --stdinisatty=false \
        '{{ if .personal }}personal{{ else if .work }}work{{ else }}none{{ end }}')
    case "$host_profile" in
        personal) DOTFILES_PERSONAL=1 ;;
        work) DOTFILES_WORK=1 ;;
    esac
}

init_secrets_overrides() {
    secrets_enabled=0
    if [ -n "${DOTFILES_SECRETS:-}" ] && is_truthy "$DOTFILES_SECRETS"; then
        secrets_enabled=1
    fi

    if [ "$secrets_enabled" -eq 1 ]; then
        resolve_host_profile

        if [ -z "${DOTFILES_PERSONAL:-}" ] && [ -z "${DOTFILES_WORK:-}" ]; then
            die "DOTFILES_SECRETS=1 but host profile unknown; set DOTFILES_PERSONAL=1 or DOTFILES_WORK=1"
        fi

        age_key_path="$HOME/.config/chezmoi/age.key"
        if [ ! -f "$age_key_path" ]; then
            die "DOTFILES_SECRETS=1 requires host age key at %s" "$age_key_path"
        fi
    fi
}

init_gnupg_overrides() {
    if [ "${with_gnupg:-0}" -eq 1 ]; then
        host_gnupg_dir="${HOME}/.gnupg"
        if [ ! -d "$host_gnupg_dir" ]; then
            die "GNUPGHOME seed requested but host path missing: %s" "$host_gnupg_dir"
        fi
    fi
}

find_distros() {
    for d in "$containerdir"/*; do
        [ -d "$d" ] || continue
        [ -f "$d/Dockerfile" ] || continue
        printf "%s\n" "${d##*/}"
    done
}

validate_distro() {
    if [ ! -f "$containerdir/$1/Dockerfile" ]; then
        die "no test container for '%s' (expected %s/%s/Dockerfile)" "$1" "$containerdir" "$1"
    fi
}

docker_server_arch() {
    # Prefer docker version formatting (fast, stable), fall back to docker info.
    arch=$(docker version -f '{{.Server.Arch}}' 2>/dev/null || true)
    if [ -n "$arch" ]; then
        printf "%s" "$arch"
        return 0
    fi
    arch=$(docker info -f '{{.Architecture}}' 2>/dev/null || true)
    if [ -n "$arch" ]; then
        printf "%s" "$arch"
        return 0
    fi
    # Unknown; let docker decide.
    printf "%s" "unknown"
}

arch_base_image_for_host() {
    if [ -n "${ARCH_BASE_IMAGE:-}" ]; then
        printf "%s" "$ARCH_BASE_IMAGE"
        return 0
    fi
    if [ "$(docker_server_arch)" = "arm64" ]; then
        printf "%s" "${ARCH_ARM64_BASE_IMAGE:-ghcr.io/baerenbude-org/archlinuxarm-arm64v8:latest}"
        return 0
    fi
    printf "%s" "archlinux/archlinux:latest"
}

build_image() {
    image_name=$1
    build_context=$2
    distro=$3

    msg "Building %s..." "$image_name"
    if [ "${distro:-}" = "arch" ]; then
        base_image=$(arch_base_image_for_host)
        msg "  arch base image: %s" "$base_image"
        # BuildKit mishandles ARG-before-FROM with the
        # check=skip=InvalidBaseImagePlatform directive; disable it for arch.
        DOCKER_BUILDKIT=0 run docker build \
            --build-arg "BASE_IMAGE=$base_image" \
            -t "$image_name" \
            "$build_context"
    else
        run docker build -t "$image_name" "$build_context"
    fi
}

run_container() {
    image_name=$1

    container_script="$dotfiles_mount/test/containers/run-test-container.sh"

    set -- \
        --rm \
        -v "$repodir:$dotfiles_mount" \
        -e NO_USER_PASSWORD=1 \
        -e DOTFILES_DIR="$dotfiles_mount" \
        -e TEST_DOTFILES_DIR="$dotfiles_mount" \
        -e TEST_DISTRO="$distro" \
        -e TEST_SETUP_MODE="$setup_mode" \
        -e TEST_ACTION="$action" \
        -e TEST_INTERACTIVE="$interactive" \
        -e TEST_USER="$user" \
        -e TEST_UID="$user_uid" \
        ${GITHUB_TOKEN:+-e GITHUB_TOKEN="$GITHUB_TOKEN"} \
        ${CLAUDE_CODE_OAUTH_TOKEN:+-e CLAUDE_CODE_OAUTH_TOKEN="$CLAUDE_CODE_OAUTH_TOKEN"} \
        ${command:+-e TEST_COMMAND="$command"} \
        -e DOTFILES_SECRETS="${DOTFILES_SECRETS:-0}" \
        ${DOTFILES_EPHEMERAL:+-e DOTFILES_EPHEMERAL="$DOTFILES_EPHEMERAL"} \
        ${DOTFILES_HEADLESS:+-e DOTFILES_HEADLESS="$DOTFILES_HEADLESS"} \
        ${DOTFILES_PERSONAL:+-e DOTFILES_PERSONAL="$DOTFILES_PERSONAL"} \
        ${DOTFILES_WORK:+-e DOTFILES_WORK="$DOTFILES_WORK"} \
        ${DOTFILES_SKIP_GPG_SECRET_IMPORT:+-e DOTFILES_SKIP_GPG_SECRET_IMPORT="$DOTFILES_SKIP_GPG_SECRET_IMPORT"} \
        ${RUN_TEST_TRACE:+-e RUN_TEST_TRACE="$RUN_TEST_TRACE"}

    if [ -s ~/.codex/auth.json ]; then
        set -- "$@" -v "$HOME/.codex/auth.json:/mounts/.codex/auth.json:ro"
    fi

    if [ "$skip_nix_cache" != "1" ]; then
        set -- "$@" \
          --mount type=volume,src=dotfiles-nix-store,dst=/nix \
          --mount "type=volume,src=dotfiles-nix-cache,dst=/home/$user/.cache/nix" \
          --mount "type=volume,src=dotfiles-nix-state,dst=/home/$user/.local/state/nix"
    fi

    if [ "${with_gnupg:-0}" -eq 1 ]; then
        set -- "$@" -e DOTFILES_TEST_GNUPG=1 -e HOST_GNUPG_DIR="/run/host-gnupg"
        set -- "$@" -v "$host_gnupg_dir:/run/host-gnupg:ro"
    fi

    if [ "${secrets_enabled:-0}" -eq 1 ]; then
        set -- "$@" -v "$age_key_path:/home/$user/.config/chezmoi/age.key:ro"
    fi

    if [ "$action" = "shell" ] || [ "$interactive" -eq 1 ]; then
        run docker run --entrypoint /bin/sh -it "$@" "$image_name" "$container_script"
    else
        run docker run --entrypoint /bin/sh -i "$@" "$image_name" "$container_script"
    fi
}

completion_msg() {
    if [ "$action" = "shell" ]; then
        printf "Interactive shell session ended"
    elif [ "$interactive" -eq 1 ]; then
        printf "Interactive setup session ended"
    elif [ "$setup_mode" = "root-only" ]; then
        printf "Root-only setup completed"
    elif [ "$setup_mode" = "user-only" ]; then
        printf "User-only setup completed"
    elif [ "$action" = "command" ]; then
        printf "Command run completed"
    else
        printf "Test completed"
    fi
}

run_one() {
    distro=$1
    image_name="dotfiles-test-$distro"
    build_context="$containerdir/$distro/"

    validate_distro "$distro"
    build_image "$image_name" "$build_context" "$distro"

    if [ "$build_only" -eq 1 ]; then
        msg "Image %s built successfully." "$image_name"
        return 0
    fi

    run_container "$image_name"
}

main() {
    process_arguments "$@"
    shift $((OPTIND - 1))

    init_secrets_overrides
    init_gnupg_overrides

    # Use $HOME rather than $TMPDIR: Colima (macOS Docker VM) doesn't mount
    # all host paths, but $HOME is reliably available inside the VM context.
    tmpdir=$(mktemp -d "$HOME/.tmp.run-test.XXXXXX")
    trap 'rm -rf "$tmpdir"' EXIT INT TERM

    if [ "$all_distros" -eq 1 ]; then
        distros=$(find_distros)
        if [ -z "$distros" ]; then
            die "no distros found under %s (expected */Dockerfile)" "$containerdir"
        fi
        echo "$distros" | while IFS= read -r d; do
            echo "$d"
        done
    else
        for distro; do
            echo "$distro"
        done
    fi >"$tmpdir/distros.txt"

    while read -r distro; do
        [ -n "$distro" ] || continue
        # The while loop redirects stdin from the distros file, so restore
        # /dev/tty when the selected mode needs real terminal input.
        # Non-interactive runs use /dev/null so CI does not need a TTY.
        if { [ "$action" = "shell" ] || [ "$interactive" -eq 1 ]; } && [ "${dry_run:-0}" -ne 1 ]; then
            if ! run_one "$distro" </dev/tty; then
                msg "Test failed for distro: %s" "$distro"
                exit 1
            fi
        else
            if ! run_one "$distro" </dev/null; then
                msg "Test failed for distro: %s" "$distro"
                exit 1
            fi
        fi
    done <"$tmpdir/distros.txt"

    label=$(completion_msg)
    # shellcheck disable=SC2046
    if [ $(wc -l <"$tmpdir/distros.txt") -gt 1 ]; then
        msg "%s for all distros: %s" "$label" "$(tr '\n' ' ' <"$tmpdir/distros.txt")"
    else
        msg "%s for distro: %s" "$label" "$distro"
    fi
}

if [ -z "${0##/*}" ]; then
    scriptdir=$(cd "$(dirname "$0")" && pwd -P)
else
    script=$(command -v "${0##*/}") || script="$0"
    scriptdir=$(cd "$(dirname "$script")" && pwd -P)
fi
containerdir="$scriptdir/containers"
repodir=$(cd "$containerdir/.." && pwd -P)

main "$@"
