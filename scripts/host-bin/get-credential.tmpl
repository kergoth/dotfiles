#!/bin/sh
set -eu

name=${1:-}
[ -n "$name" ] || {
    printf 'usage: %s NAME\n' "${0##*/}" >&2
    exit 2
}

lookup_cli() {
    case "$1" in
        GITHUB_TOKEN)
            command -v gh >/dev/null 2>&1 || return 1
            env GITHUB_TOKEN= gh auth token
            ;;
        *)
            return 1
            ;;
    esac
}

lookup_keychain() {
    os="{{ .chezmoi.os }}"
    case "$os" in
        darwin)
            command -v security >/dev/null 2>&1 || return 1
            security find-generic-password -s "$1" -a "${USER:-$(id -un)}" -w
            ;;
        linux|freebsd)
            command -v secret-tool >/dev/null 2>&1 || return 1
            secret-tool lookup service dotfiles key "$1"
            ;;
        *)
            return 1
            ;;
    esac
}

if value=$(lookup_cli "$name" 2>/dev/null); then
    printf '%s' "$value"
    exit 0
fi

if value=$(lookup_keychain "$name" 2>/dev/null); then
    printf '%s' "$value"
    exit 0
fi

exit 0
