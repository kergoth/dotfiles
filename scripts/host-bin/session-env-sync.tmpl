#!/bin/sh
set -eu

backend=${1:-}
[ -n "$backend" ] || {
    printf 'usage: %s {launchctl|dbus}\n' "${0##*/}" >&2
    exit 2
}

launchctl_cmd=launchctl
dbus_cmd=dbus-update-activation-environment

if command -v launchctl >/dev/null 2>&1; then
    launchctl_cmd=$(command -v launchctl)
fi
if command -v dbus-update-activation-environment >/dev/null 2>&1; then
    dbus_cmd=$(command -v dbus-update-activation-environment)
fi

PATH="$HOME/bin:$HOME/.local/bin:$HOME/.nix-profile/bin:$HOME/.brew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
export PATH

# shellcheck source=/dev/null
. "$HOME/.envrc"
: "${SESSION_VARS:=PATH GITHUB_TOKEN CLAUDE_CODE_OAUTH_TOKEN}"

for var in $SESSION_VARS; do
    case "$var" in
        ''|[!A-Za-z_]*|*[!A-Za-z0-9_]*)
            continue
            ;;
    esac
    eval "val=\${$var-}"
    [ -n "${val-}" ] || continue
    case "$backend" in
        launchctl)
            target_uid=$("$launchctl_cmd" manageruid 2>/dev/null || id -u)
            "$launchctl_cmd" asuser "$target_uid" "$launchctl_cmd" setenv "$var" "$val"
            ;;
        dbus)
            "$dbus_cmd" "$var=$val"
            ;;
        *)
            printf 'unknown backend: %s\n' "$backend" >&2
            exit 2
            ;;
    esac
done
