#!/bin/sh
set -eu

usage() {
    printf 'usage: %s NAME [VALUE]\n' "${0##*/}" >&2
}

name=${1:-}
[ -n "$name" ] || {
    usage
    exit 2
}

if [ $# -gt 1 ]; then
    value=$2
else
    if [ -t 0 ]; then
        printf 'missing VALUE argument; pass VALUE or pipe it on stdin\n' >&2
        exit 2
    fi
    IFS= read -r value || value=
fi

os="{{ .chezmoi.os }}"
case "$os" in
    darwin)
        command -v security >/dev/null 2>&1 || exit 1
        security add-generic-password -U -s "$name" -a "${USER:-$(id -un)}" -w "$value" >/dev/null
        ;;
    linux|freebsd)
        command -v secret-tool >/dev/null 2>&1 || exit 1
        printf '%s' "$value" |
            secret-tool store --label="$name" service dotfiles key "$name" >/dev/null
        ;;
    *)
        printf 'unsupported OS: %s\n' "$os" >&2
        exit 1
        ;;
esac
