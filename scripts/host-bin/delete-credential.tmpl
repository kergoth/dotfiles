#!/bin/sh
set -eu

usage() {
    printf 'usage: %s NAME\n' "${0##*/}" >&2
}

name=${1:-}
[ -n "$name" ] || {
    usage
    exit 2
}

os="{{ .chezmoi.os }}"
case "$os" in
    darwin)
        command -v security >/dev/null 2>&1 || exit 1
        security delete-generic-password -s "$name" -a "${USER:-$(id -un)}" >/dev/null
        ;;
    linux|freebsd)
        command -v secret-tool >/dev/null 2>&1 || exit 1
        secret-tool clear service dotfiles key "$name" >/dev/null
        ;;
    *)
        printf 'unsupported OS: %s\n' "$os" >&2
        exit 1
        ;;
esac
