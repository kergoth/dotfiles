#!/usr/bin/env bash
# Usage: mas-check-pricing [options] [file ...]
#
# Check pricing (free vs paid) for Mac App Store items in Brewfile templates.
# Reads mas entries from the given files (or stdin), queries the iTunes Search
# API, and reports each app's price.
#
# With -i, free apps are also checked for in-app purchases by fetching the App
# Store page and reading the Information list with pup (one request per free
# app; page markup can change). FREE+IAP means the store lists In-App Purchases,
# not that payment is required to use the app. Requires pup on PATH, or nix to
# run nixpkgs#pup.
#
# Options:
#     -p          Show only paid apps
#     -f          Show only free apps (includes FREE+IAP when -i is set)
#     -i          Also detect in-app purchases on free apps (App Store + pup)
#     -n          Dry run, show parsed entries without querying
#     -v          Increase verbosity
#     -q          Decrease verbosity
#     -h          Show this help message
set -euo pipefail

scriptname=${BASH_SOURCE[0]##*/}

verbosity=0
dry_run=0
filter=all
check_iap=0
pup_bin=

msg() {
    local fmt=$1
    if [ $# -gt 1 ]; then
        shift
    fi
    # shellcheck disable=SC2059
    printf -- "$fmt\n" "$@" >&2
}

msg_color() {
    local color=$1
    shift
    local fmt=$1
    shift
    # shellcheck disable=SC2059
    if [ -n "${NO_COLOR:-}" ] || { [ -z "${COLOR:-}" ] && ! [ -t 1 ]; }; then
        printf "${fmt}\n" "$@" >&2
    else
        printf "\033[${color}m${fmt}\033[0m\n" "$@" >&2
    fi
}

msg_green() { msg_color "32" "$@"; }
msg_red() { msg_color "31" "$@"; }
msg_yellow() { msg_color "33" "$@"; }
msg_cyan() { msg_color "36" "$@"; }
msg_verbose() {
    if [ "${verbosity:-0}" -gt 0 ]; then
        msg_yellow "$@"
    fi
}

die() {
    msg_red "$@"
    exit 1
}

usage() {
    sed -n '/^# Usage:/,/^# *-h /p' "${BASH_SOURCE[0]}" | sed 's/^# *//'
}

process_arguments() {
    while getopts "pfinvqh" opt; do
        case $opt in
        p) filter=paid ;;
        f) filter=free ;;
        i) check_iap=1 ;;
        n) dry_run=1 ;;
        v) verbosity=$((verbosity + 1)) ;;
        q) verbosity=$((verbosity - 1)) ;;
        h)
            usage
            exit 0
            ;;
        \?)
            echo "Unknown option: -$OPTARG" >&2
            usage >&2
            exit 1
            ;;
        esac
    done
    shift $((OPTIND - 1))

    files=("$@")
}

extract_mas_entries() {
    local line name app_id
    while IFS= read -r line; do
        if [[ $line =~ ^[[:space:]]*mas[[:space:]]+\"([^\"]+)\",?[[:space:]]*id:[[:space:]]*([0-9]+) ]]; then
            name=${BASH_REMATCH[1]}
            app_id=${BASH_REMATCH[2]}
            printf '%s\t%s\n' "$app_id" "$name"
        fi
    done
}

query_pricing() {
    local ids=$1
    curl -sf "https://itunes.apple.com/lookup?media=software&entity=desktopSoftware&country=US&id=$ids" \
        | jq -r '.results[] | [(.trackId | tostring), .trackName, (.price // 0 | tostring), (.formattedPrice // "Unknown")] | @tsv'
}

ensure_pup() {
    if [ -n "$pup_bin" ]; then
        return
    fi

    if command -v pup >/dev/null 2>&1; then
        pup_bin=$(command -v pup)
        msg_verbose "Using pup at %s" "$pup_bin"
        return
    fi

    if ! command -v nix >/dev/null 2>&1; then
        die "IAP checks require pup on PATH, or nix to run nixpkgs#pup"
    fi

    msg_verbose "pup not on PATH; resolving nixpkgs#pup..."
    local pup_out
    pup_out=$(nix build --no-link --print-out-paths nixpkgs#pup) \
        || die "Failed to resolve nixpkgs#pup"
    pup_bin=${pup_out}/bin/pup
    if [ ! -x "$pup_bin" ]; then
        die "Resolved nixpkgs#pup but %s is not executable" "$pup_bin"
    fi
    msg_verbose "Using pup at %s" "$pup_bin"
}

# Returns: 0 = has IAP, 1 = no IAP, 2 = unknown / fetch failed
app_has_iap() {
    local app_id=$1
    local html dts
    local curl_status=0

    html=$(curl -sfL --max-time 30 -A 'Mozilla/5.0' \
        "https://apps.apple.com/us/app/id${app_id}") || curl_status=$?
    if [ "$curl_status" -ne 0 ] || [ -z "$html" ]; then
        return 2
    fi

    dts=$(printf '%s' "$html" | "$pup_bin" 'dt text{}') || return 2
    if [ -z "$dts" ]; then
        return 2
    fi

    # Match ASCII or Unicode non-breaking hyphen variants in the label.
    if printf '%s\n' "$dts" | grep -qE '^In[-‑]App Purchases$'; then
        return 0
    fi
    if printf '%s\n' "$dts" | grep -q '^Seller$'; then
        return 1
    fi
    return 2
}

main() {
    process_arguments "$@"

    local entries
    if [ ${#files[@]} -eq 0 ]; then
        entries=$(extract_mas_entries)
    else
        entries=$(cat "${files[@]}" | extract_mas_entries)
    fi

    if [ -z "$entries" ]; then
        die "No mas entries found"
    fi

    local ids
    ids=$(echo "$entries" | cut -f1 | paste -sd, -)
    local count
    count=$(echo "$entries" | wc -l | tr -d ' ')

    msg_verbose "Found %d app(s), querying iTunes API..." "$count"

    if [ "$dry_run" -eq 1 ]; then
        msg "Parsed entries (dry run):"
        echo "$entries" | while IFS=$'\t' read -r app_id name; do
            printf "  %s  %s\n" "$app_id" "$name"
        done
        return
    fi

    if [ "$check_iap" -eq 1 ]; then
        ensure_pup
    fi

    local results
    results=$(query_pricing "$ids")

    if [ -z "$results" ]; then
        die "No results from iTunes API"
    fi

    local found_ids
    found_ids=$(echo "$results" | cut -f1)

    local missing_ids
    missing_ids=$(comm -23 \
        <(echo "$entries" | cut -f1 | sort) \
        <(echo "$found_ids" | sort))

    local free_count=0
    local free_iap_count=0
    local paid_count=0
    local iap_unknown_count=0

    while IFS=$'\t' read -r app_id name price formatted; do
        local is_free=0
        if [ "$price" = "0" ] || [ "$formatted" = "Free" ]; then
            is_free=1
        fi

        if [ "$filter" = "paid" ] && [ "$is_free" -eq 1 ]; then
            continue
        fi
        if [ "$filter" = "free" ] && [ "$is_free" -eq 0 ]; then
            continue
        fi

        if [ "$is_free" -eq 1 ]; then
            local iap_status=none
            if [ "$check_iap" -eq 1 ]; then
                local iap_rc=0
                msg_verbose "Checking IAP for %s (id: %s)..." "$name" "$app_id"
                app_has_iap "$app_id" || iap_rc=$?
                case $iap_rc in
                0) iap_status=yes ;;
                1) iap_status=no ;;
                *) iap_status=unknown ;;
                esac
            fi

            case $iap_status in
            yes)
                free_iap_count=$((free_iap_count + 1))
                msg_cyan "  FREE+IAP %s (id: %s)" "$name" "$app_id"
                ;;
            unknown)
                free_count=$((free_count + 1))
                iap_unknown_count=$((iap_unknown_count + 1))
                msg_green "  FREE?    %s (id: %s) — IAP check failed" "$name" "$app_id"
                ;;
            *)
                free_count=$((free_count + 1))
                msg_green "  FREE     %s (id: %s)" "$name" "$app_id"
                ;;
            esac
        else
            paid_count=$((paid_count + 1))
            msg_yellow "  %-8s %s (id: %s)" "$formatted" "$name" "$app_id"
        fi
    done <<< "$results"

    if [ -n "$missing_ids" ]; then
        while IFS= read -r mid; do
            local mname
            mname=$(echo "$entries" | grep "^$mid" | cut -f2)
            msg_red "  ???      %s (id: %s) — not found in App Store" "$mname" "$mid"
        done <<< "$missing_ids"
    fi

    if [ "$filter" = "all" ]; then
        msg ""
        if [ "$check_iap" -eq 1 ]; then
            msg "Total: %d free, %d free+iap, %d paid" \
                "$free_count" "$free_iap_count" "$paid_count"
            if [ "$iap_unknown_count" -gt 0 ]; then
                msg "(%d free app(s) could not be checked for IAP)" "$iap_unknown_count"
            fi
        else
            msg "Total: %d free, %d paid" "$free_count" "$paid_count"
        fi
    fi
}

main "$@"
