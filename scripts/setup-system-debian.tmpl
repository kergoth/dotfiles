#!/usr/bin/env chezmoi-exec
{{- $codename := .chezmoi.osRelease.versionCodename -}}
{{- $add_tailscale := and (not .work) (not .ephemeral) -}}
{{- $add_onepassword := and (not .headless) (not .work) (not .ephemeral) -}}
#!/usr/bin/env bash

set -euo pipefail

scriptdir=$(cd "$(dirname "$0")" && pwd -P)
PATH="$scriptdir/debian:$scriptdir/linux:$scriptdir:$PATH"

# shellcheck source=./common.sh
. "$scriptdir/common.sh" || exit 1

need_sudo

if ! has xz || ! has zsh; then
    sudorun env DEBIAN_FRONTEND=noninteractive apt-get -y update
fi

# Install xz for nix
if ! has xz; then
    sudorun env DEBIAN_FRONTEND=noninteractive apt-get -y install xz-utils
fi

if ! has zsh; then
    sudorun env DEBIAN_FRONTEND=noninteractive apt-get -y install zsh
fi

if ! has file; then
    sudorun env DEBIAN_FRONTEND=noninteractive apt-get -y install file
fi

{{ if not .headless -}}
# Install KDE Plasma and display manager
sudorun env DEBIAN_FRONTEND=noninteractive apt-get -y update
sudorun env DEBIAN_FRONTEND=noninteractive apt-get -y install kde-plasma-desktop sddm okular filelight

{{ if and (not .ephemeral) (not .wsl2) (not (env "CONTAINER_ID")) -}}
{{   if .has_init -}}
# Enable sddm
sudorun systemctl enable sddm.service
if pgrep systemd &>/dev/null; then
    sudorun systemctl start sddm
fi
{{-   end }}
{{- end }}

# Flatpak
sudorun env DEBIAN_FRONTEND=noninteractive apt-get -y install flatpak
sudorun flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
{{- end }}

{{ if or $add_tailscale $add_onepassword -}}
# Add external repositories
sudo mkdir -p --mode=0755 /usr/share/keyrings

{{ if $add_tailscale -}}
curl -fsSL "https://pkgs.tailscale.com/stable/debian/{{ $codename }}.noarmor.gpg" | sudo tee /usr/share/keyrings/tailscale-archive-keyring.gpg >/dev/null
curl -fsSL "https://pkgs.tailscale.com/stable/debian/{{ $codename }}.tailscale-keyring.list" | sudo tee /etc/apt/sources.list.d/tailscale.list
{{ end -}}
{{ if $add_onepassword -}}
op_arch="$(dpkg --print-architecture)"
case "$op_arch" in
    amd64)
        curl -sS https://downloads.1password.com/linux/keys/1password.asc | \
            sudo gpg --dearmor --output /usr/share/keyrings/1password-archive-keyring.gpg
        echo "deb [arch=amd64 signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/amd64 stable main" | \
            sudo tee /etc/apt/sources.list.d/1password.list
        onepassword_install="apt"
        msg "1Password install mode: apt (amd64 repo)"
        ;;
    arm64)
        onepassword_install="tar"
        msg "1Password install mode: tarball (arm64)"
        ;;
    *)
        msg "Skipping 1Password: unsupported architecture: $op_arch"
        onepassword_install="skip"
        ;;
esac
{{ end -}}
sudorun env DEBIAN_FRONTEND=noninteractive apt-get -y update

{{ if $add_tailscale -}}
sudorun env DEBIAN_FRONTEND=noninteractive apt-get -y install tailscale
{{   if .has_init -}}
sudorun systemctl enable tailscaled
if pgrep systemd &>/dev/null; then
    sudorun systemctl start tailscaled
    sudorun tailscale up
fi
{{-   end }}
{{ end -}}
{{ if $add_onepassword -}}
if [ "${onepassword_install:-}" = "apt" ]; then
    sudorun env DEBIAN_FRONTEND=noninteractive apt-get -y install 1password
elif [ "${onepassword_install:-}" = "tar" ]; then
    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' EXIT INT TERM
    onepassword_install_tarball "$tmpdir"
fi
{{ end -}}
{{- end }}
