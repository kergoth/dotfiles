#!/usr/bin/env chezmoi-exec
#!/usr/bin/env bash

set -eu

scriptdir=$(cd "$(dirname "$0")" && pwd -P)
PATH="$scriptdir/freebsd:$scriptdir:$PATH"

# shellcheck source=./common.sh
. "$scriptdir/common.sh" || exit 1

if [ "$(id -u)" != "0" ]; then
    # Re-execute ourselves as root. We need to re-execute the generated temporary file created by chezmoi-exec,
    # but need to make sure we keep overriding $0 to its original path, and overriding $0 in a shell script
    # requires that it be sourced.
    doas env PATH="$PATH" bash -c "exec -a \"$0\" bash -c \". \\\"$CHEZMOI_EXEC_SCRIPT\\\" \\\"$USER\\\"\""
    exit $?
fi

tmpdir=$(mktemp -d -t "${0##*/}.XXXXXXX")
trap 'rm -rf "$tmpdir"' EXIT INT TERM

username="$1"
shift

pkg_install_freebsd() {
    msg "Installing '$1'"
    env ASSUME_ALWAYS_YES=YES pkg install "$@"
}

port_install() {
    if [ -z "$1" ]; then
        die "port_install requires a package argument"
    fi

    if [ -d /usr/ports/"$1" ]; then
        msg "Installing port '$1'"
        (
            cd "/usr/ports/$1" || exit 1
            for variable in LIB_DEPENDS BUILD_DEPENDS; do
                make -V "$variable"
            done | xargs -n 1 echo | cut -d: -f2 | sort -u | xargs --no-run-if-empty -o pkg install --automatic
            make MAKE_JOBS_UNSAFE=yes install
        )
    else
        die "No port found for $1"
    fi
}

freebsd_check() {
    pkg="$1"
    cmd="${2:-}"

    if [ -n "$cmd" ] && command -v "$cmd" >/dev/null 2>&1; then
        return 0
    fi

    if pkg search --exact "$pkg" >/dev/null 2>&1; then
        pkgs="$pkgs $pkg"
    else
        ports="$ports $pkg"
    fi
}

ports=
pkgs=

freebsd_check shells/zsh zsh
#freebsd_check sysutils/nix nix

freebsd_check devel/git git
freebsd_check devel/git-lfs git-lfs
freebsd_check ftp/wget wget
freebsd_check ftp/curl curl

freebsd_check editors/neovim nvim
freebsd_check sysutils/tmux tmux

freebsd_check lang/rust cargo
freebsd_check lang/go go
freebsd_check lang/python310 python3.10
freebsd_check lang/python3 python3
freebsd_check devel/uv uv
freebsd_check www/node node

freebsd_check sysutils/chezmoi chezmoi

{{ if and (not .work) (not .ephemeral) -}}
# VPN
freebsd_check security/tailscale tailscale
{{- end }}

# GnuPG
freebsd_check security/gnupg gpg
freebsd_check security/libsecret secret-tool

freebsd_check sysutils/duf duf
freebsd_check sysutils/fd fd
freebsd_check textproc/ripgrep rg
freebsd_check sysutils/zoxide zoxide
freebsd_check textproc/sd sd
freebsd_check textproc/sad sad
freebsd_check sysutils/tealdeer tldr
freebsd_check archivers/unarchiver unar
freebsd_check archivers/zstd zstd
freebsd_check textproc/fzf fzf
freebsd_check shells/atuin atuin
freebsd_check textproc/choose choose

# SCM & Related
freebsd_check devel/git-delta delta
freebsd_check devel/gh gh
freebsd_check sysutils/glow glow
freebsd_check devel/ghq ghq
freebsd_check devel/git-absorb git-absorb
freebsd_check misc/patchutils filterdiff
freebsd_check devel/jujutsu jj
freebsd_check textproc/difftastic difftastic

# Disk tools
freebsd_check sysutils/dua-cli dua
freebsd_check sysutils/fclones fclones

# Backup tools
freebsd_check net/rsync rsync
freebsd_check sysutils/restic restic

# Linting and formatting
freebsd_check devel/hs-ShellCheck shellcheck
freebsd_check devel/shfmt shfmt

# Development, work
{{ if .work -}}
freebsd_check www/jira-cli jira
{{- end }}

# Containers
{{ if .containers -}}
freebsd_check sysutils/podman-suite podman
{{- end }}

# Directly supported by nix home-manager
freebsd_check textproc/jq jq
freebsd_check textproc/bat bat
freebsd_check sysutils/exa exa
freebsd_check sysutils/direnv direnv

# LLM
if pkg info -e claude-code >/dev/null 2>&1; then
    pkg delete -y claude-code
fi

# FreeBSD-only
freebsd_check sysutils/lsblk lsblk

# GUI Applications
{{ if not .headless -}}
freebsd_check x11/xorg Xorg
freebsd_check x11/plasma6-plasma startplasma-x11
freebsd_check x11/sddm sddm
freebsd_check www/librewolf librewolf
freebsd_check x11/kitty kitty
freebsd_check editors/zed zed
freebsd_check graphics/okular okular
freebsd_check sysutils/filelight filelight
{{ if and .user_setup (not .ephemeral) -}}
freebsd_check deskutils/syncthingtray syncthingtray
{{- end }}
freebsd_check security/pinentry-qt6 pinentry-qt6
{{ if not .work -}}
#freebsd_check transmission-remote-gui-qt6 transgui
{{- end }}
{{ if .ebook_library -}}
freebsd_check deskutils/calibre calibre
{{- end }}
{{ if .gaming_device_library -}}
freebsd_check games/scummvm scummvm
{{- end }}
{{ if .music_library -}}
freebsd_check audio/picard picard
{{- end }}
{{ if .video -}}
freebsd_check multimedia/vlc vlc
{{- end }}
{{- end }}

# Add user to operator and video groups
pw groupmod operator -m "$USER"
pw groupmod video -m "$USER"

# Installation
if [ -n "$(echo "$pkgs" | sed -e 's/^ *//; s/ *$//')" ]; then
    echo "$pkgs" | tr ' ' '\n' | sort -u | tr '\n' '\0' | xargs -0 --no-run-if-empty -o env ASSUME_ALWAYS_YES=YES pkg install
fi

if [ -n "$(echo "$ports" | sed -e 's/^ *//; s/ *$//')" ]; then
    for port in $ports; do
        port_install "$port" || die "Failed to install $port"
    done
fi

if [ -e /usr/local/bin/zsh ]; then
    current_shell="$(getent passwd "$USER" | sed -e 's#.*:##')"
    if [ "$current_shell" != /usr/local/bin/zsh ]; then
        msg "Changing current user shell to zsh"
        chsh -s /usr/local/bin/zsh "$USER"
    fi
fi

{{ if not .ephemeral -}}
# SSH
if ! service sshd onestatus >/dev/null 2>&1; then
    sysrc sshd_enable=YES
    service sshd start
fi
{{- end }}

{{ if not .headless -}}
if ! service dbus onestatus >/dev/null 2>&1; then
    sysrc dbus_enable=YES
fi

if ! service sddm onestatus >/dev/null 2>&1; then
    sysrc sddm_enable=YES
    service sddm start || :
fi
{{- end }}

{{ if and (not .headless) (not .ephemeral) -}}
# Setup linuxulator for glibc GUI apps (1Password, Vivaldi)
bash "$scriptdir/setup-linuxulator-freebsd.sh"
{{- end }}
