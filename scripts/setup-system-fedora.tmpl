#!/usr/bin/env chezmoi-exec
{{- $ver := .chezmoi.osRelease.versionID | atoi -}}
{{- $tailscaleURL := "https://pkgs.tailscale.com/stable/fedora/tailscale.repo" -}}
{{- if le $ver 39 -}}
{{-   $tailscaleURL = printf "https://pkgs.tailscale.com/stable/fedora/%s/tailscale.repo" .chezmoi.osRelease.versionID -}}
{{- end -}}
#!/usr/bin/env bash

set -euo pipefail

scriptdir=$(cd "$(dirname "$0")" && pwd -P)
PATH="$scriptdir/debian:$scriptdir/linux:$scriptdir:$PATH"

# shellcheck source=./common.sh
. "$scriptdir/common.sh" || exit 1

# Install xz for nix
if ! has xz; then
    sudorun dnf -y --setopt=install_weak_deps=False install xz
fi

# Install zsh
if ! has zsh; then
    sudorun dnf -y --setopt=install_weak_deps=False install zsh
fi

# Install neovim
sudorun dnf -y --setopt=install_weak_deps=False install neovim

{{ if not .headless -}}
# Install KDE Plasma and display manager
sudorun dnf -y --setopt=install_weak_deps=False install @kde-desktop-environment sddm

{{ if and (not .ephemeral) (not .wsl2) (not (env "CONTAINER_ID")) -}}
{{   if .has_init -}}
# Enable sddm
sudorun systemctl enable --force --now sddm.service
{{-   end }}
{{- end }}

# Terminal emulator
sudorun dnf -y --setopt=install_weak_deps=False install kitty

# Flatpak
sudorun dnf -y --setopt=install_weak_deps=False install flatpak
sudorun flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
{{- end }}

# Install, enable, and start Tailscale
{{ if and (not .work) (not .ephemeral) -}}
{{ if ge $ver 41 }}
{{/* DNF 5 */}}
sudorun dnf config-manager addrepo --from-repofile={{ $tailscaleURL }}
{{ else }}
sudorun dnf config-manager --add-repo {{ $tailscaleURL }}
{{- end }}
sudorun dnf -y --setopt=install_weak_deps=False install tailscale
{{   if .has_init -}}
sudorun systemctl enable --now tailscaled
sudorun tailscale up
{{-   end }}
{{- end }}

{{ if and (not .headless) (not .work) (not .ephemeral) -}}
# Install 1Password
sudo rpm --import https://downloads.1password.com/linux/keys/1password.asc
sudo sh -c 'echo -e "[1password]\nname=1Password Stable Channel\nbaseurl=https://downloads.1password.com/linux/rpm/stable/\$basearch\nenabled=1\ngpgcheck=1\nrepo_gpgcheck=1\ngpgkey=\"https://downloads.1password.com/linux/keys/1password.asc\"" > /etc/yum.repos.d/1password.repo'
sudorun dnf -y --setopt=install_weak_deps=False install 1password
{{- end }}
