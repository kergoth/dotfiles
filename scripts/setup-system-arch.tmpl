#!/usr/bin/env chezmoi-exec
{{- if not .steamdeck -}}
#!/usr/bin/env bash

set -euo pipefail

scriptdir=$(cd "$(dirname "$0")" && pwd -P)
PATH="$scriptdir/arch:$scriptdir/linux:$scriptdir:$PATH"

# shellcheck source=./common.sh
. "$scriptdir/common.sh" || exit 1

locale="en_US.UTF-8"

need_sudo

# Partial upgrades are unsupported on Arch - always full upgrade first
sudorun pacman -Syu --noconfirm

# Keyring can become outdated on fresh/dormant installs
pacman_install archlinux-keyring

# Sync the files database
sudorun pacman -Fy

# Locales
sudorun sed -i -e "/^#$locale /s/^#//" /etc/locale.gen
sudorun locale-gen
echo "LANG=$locale" | sudorun tee /etc/locale.conf

# Timezone
timezone="America/Phoenix"
if [ ! -e /etc/localtime ] || [ "$(readlink -f /etc/localtime 2>/dev/null)" != "/usr/share/zoneinfo/$timezone" ]; then
    sudorun ln -sf /usr/share/zoneinfo/$timezone /etc/localtime
fi

# Allow non-root users to install to /usr/local
if ! getent group staff >/dev/null 2>&1; then
    sudorun groupadd -r -g 51 staff
fi
sudorun chgrp -R staff /usr/local
sudorun chmod -R g+rwX /usr/local
sudorun find /usr/local -type d -exec chmod g+s "{}" \;

pacman_install openssh

if ! grep -q '^MAKEFLAGS=.*-j' /etc/makepkg.conf; then
    CPUS=$(grep -c processor /proc/cpuinfo)
    JOBS=$((CPUS * 3 / 2))
    sudorun sed -i -e "s,#*MAKEFLAGS=.*,MAKEFLAGS=\"-j$JOBS\"," /etc/makepkg.conf
    if ! grep -q '^MAKEFLAGS=.*-j' /etc/makepkg.conf; then
        echo >&2 "Warning: failed to set MAKEFLAGS=-j$JOBS in /etc/makepkg.conf"
    fi
fi

pacman_install vi zsh which xz

{{ if and .use_nix (not .wsl2) .has_init -}}
if ! has nix; then
    pacman_install nix
fi

if ! grep -q "^nix-users:.*$USER" /etc/group; then
    sudorun sed -i -e "/^nix-users:/s/\$/ $USER/; /^nix-users:/s/: /:/;" /etc/group
    if ! grep -q "^nix-users:.*$USER" /etc/group; then
        echo >&2 "Failed to add user to the nix-users group, please do so manually, then re-login"
    else
        echo >&2 "User has been added to the nix-users group, please re-login"
    fi
fi

if pgrep systemd >/dev/null 2>&1; then
    sudorun systemctl enable nix-daemon
    sudorun systemctl start nix-daemon
else
    echo >&2 "Warning: no systemd running, unable to start nix daemon"
fi
{{- end }}

# Wget, unzip for installation of password manager cli
pacman_install wget unzip

{{ if not .headless -}}
# Install KDE Plasma and display manager
pacman_install plasma-desktop sddm okular filelight

{{ if and (not .ephemeral) (not .wsl2) (not (env "CONTAINER_ID")) -}}
{{   if .has_init -}}
# Enable sddm
sudorun systemctl enable sddm.service
if pgrep systemd &>/dev/null; then
    sudorun systemctl start sddm.service
fi
{{-   end }}
{{- end }}

# Terminal emulator
pacman_install kitty

{{   if and (not .ephemeral) (eq .chezmoi.arch "amd64") -}}
# Vivaldi browser (amd64/x86_64 only — no arm64 package in official repos)
pacman_install vivaldi
{{-   end }}

# Flatpak
pacman_install flatpak
sudorun flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo

{{ if and (not .work) (not .ephemeral) -}}
op_arch="$(uname -m)"
case "$op_arch" in
    x86_64)
        onepassword_install="aur"
        msg "1Password install mode: AUR (x86_64)"
        ;;
    aarch64|arm64)
        onepassword_install="tar"
        msg "1Password install mode: tarball (arm64)"
        ;;
    *)
        onepassword_install="skip"
        msg "Skipping 1Password: unsupported architecture: $op_arch"
        ;;
esac

if [ "${onepassword_install:-}" = "aur" ]; then
    # Install 1Password from AUR
    "$scriptdir/extras/install-aur" 1password
elif [ "${onepassword_install:-}" = "tar" ]; then
    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' EXIT INT TERM
    onepassword_install_tarball "$tmpdir"
fi
{{- end }}
{{- end }}

# Clean up
if command pacman -Q nano >/dev/null 2>&1; then
    sudorun pacman --noconfirm -R nano || :
fi

{{ if and (not .ephemeral) (not .wsl2) -}}
{{   if not .headless -}}
if ! pacman -Q terminus-font >/dev/null 2>&1; then
    # Console font for bare-metal installations
    pacman_install terminus-font
    echo "FONT=ter-220n" | sudorun tee /etc/vconsole.conf
fi
{{- end }}

{{ if .has_init -}}
sudorun systemctl enable sshd
if pgrep systemd &>/dev/null; then
    sudorun systemctl start sshd
fi
{{- end }}

pacman_install nss-mdns avahi
sudorun sed -i -e '/hosts:/{ s/mdns_minimal //g; s/dns/mdns_minimal dns/; }' /etc/nsswitch.conf
if ! grep -q 'hosts:.*mdns_minimal' /etc/nsswitch.conf; then
    echo >&2 "Warning: failed to add mdns_minimal to hosts resolution in /etc/nsswitch.conf"
fi

{{ if .has_init -}}
sudorun systemctl enable avahi-daemon.service || true
if pgrep systemd &>/dev/null; then
    sudorun systemctl start avahi-daemon.service || true
fi
{{- end }}

{{   if not .work -}}
# Install, enable, and start Tailscale
pacman_install tailscale
{{     if .has_init -}}
sudorun systemctl enable tailscaled
if pgrep systemd &>/dev/null; then
    sudorun systemctl start tailscaled
    sudorun tailscale up
fi
{{-     end }}
{{-   end }}
{{- end }}
{{- end }}
